# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

# ─── Docker Compose interpolation variables ───────────────────────────────────
# These are read by Docker Compose (for ${VAR} substitution in compose*.yaml), not
# by Symfony. Defaults below are the conventional dev ports; override any of them
# per-machine in .env.local (loaded on both `make` and bare `docker compose` via
# COMPOSE_ENV_FILES=.env,.env.local). Changing POSTGRES_* only takes effect on a
# fresh DB volume — see .env.local.example.
APP_PORT=8000
ADMINER_PORT=8080
SMTP_MAIL_PORT=1025
SMTP_UI_PORT=8025
# Host user mapped into the php container so bind-mount writes are owned by you.
# 1000:1000 covers the common single-user Linux/WSL2 host; `make` overrides these
# with the live `id -u`/`id -g`. Bare `docker compose` uses these defaults.
UID=1000
GID=1000
# Postgres credentials — single source of truth for the DB container AND the
# composed DATABASE_URL on the php service (see compose.yaml).
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=password
# ──────────────────────────────────────────────────────────────────────────────

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Symfony's canonical Postgres DSN. Composed from POSTGRES_* (defined above) so
# credentials live in exactly one place. This value is only consulted when
# nothing overrides it; in practice it is always overridden:
#   - local Docker: compose.yaml's php service injects DATABASE_URL with
#     host=database (the compose service name) using the same POSTGRES_* values
#   - production:   /var/www/slack-cz/.env.local (written by setup-server.sh)
#   - CI:           DATABASE_URL set in the workflow env (SQLite)
# Host stays 127.0.0.1 here because that's the non-Docker default; the
# compose-injected override uses host=database, which can't share a variable.
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:5432/${POSTGRES_DB}?serverVersion=16&charset=utf8"
OLD_DATABASE_URL="mysql://root:root@mysql:3306/old?serverVersion=8.4&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

# Public base URL of the site. Used by framework.router.default_uri so that
# CLI commands (e.g. app:user:reset-password) generate absolute URLs with the
# correct host. Override per-env in .env.local (prod = https://beta.slack.cz).
APP_URL=http://localhost:8000

###> youtube ###
# Get a key from https://console.cloud.google.com → Credentials → Create API key
# Restrict it to YouTube Data API v3 + HTTP referrers in production.
# Keep the real value in .env.local — never commit it here.
YOUTUBE_API_KEY=
###< youtube ###

###> docs ###
# Optional GitHub PAT pro /docs (online wiki). Bez tokenu funguje, ale GH API
# rate limit je 60/h/IP — s PAT je 5000/h. Skutečnou hodnotu vlož do .env.local.
DOCS_GITHUB_TOKEN=
###< docs ###

###> wiki ###
# Optional GitHub PAT pro /wiki (highline guidebook). Stejné rate-limit důvody
# jako u DOCS_GITHUB_TOKEN. Skutečnou hodnotu vlož do .env.local.
WIKI_GITHUB_TOKEN=
###< wiki ###
