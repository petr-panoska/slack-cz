# Default: let Git auto-detect text vs. binary.
* text=auto

# Force LF line endings for files that MUST run as scripts inside Linux
# containers (kernel reads `#!/usr/bin/env php\r` literally — fails).
# Without this, `core.autocrlf=true` on Windows / WSL2 clients silently
# breaks `bin/console`, `bin/phpunit`, and every shell script.
bin/*           text eol=lf
*.sh            text eol=lf
Dockerfile      text eol=lf
Makefile        text eol=lf

# YAML / Dockerfile / env files: LF only. Compose tolerates CRLF, but
# the override never improves over LF.
*.yaml          text eol=lf
*.yml           text eol=lf
*.env           text eol=lf
.env*           text eol=lf
.dockerignore   text eol=lf
.gitignore      text eol=lf

# PHP / Twig / config: LF.
*.php           text eol=lf
*.twig          text eol=lf
*.json          text eol=lf
*.xml           text eol=lf

# Markdown / docs: LF (matches editorconfig).
*.md            text eol=lf

# Binary — never touch line endings.
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.webp          binary
*.ico           binary
*.pdf           binary
*.zip           binary
*.gz            binary
*.tgz           binary
