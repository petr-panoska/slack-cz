<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon"
        href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap">
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body>
    {% set music_tracks = [
        { title: 'Night Train',               artist: 'Octosound',                 src: asset('audio/octosound-night-train-175993.mp3') },
        { title: 'Dark Wave 80s Retro Vibes', artist: 'nickpanekAIassets',         src: asset('audio/nickpanekaiassets-dark-wave-80s-retro-vibes.mp3') },
        { title: 'Neonscapes',                artist: 'FSM Team feat. <e s c p>', src: asset('audio/fsm_team-neonscapes.mp3') },
        { title: 'Magenta Metropolis',        artist: 'FSM Team feat. <e s c p>', src: asset('audio/fsm_team-magenta-metropolis.mp3') },
        { title: 'Strange Time',              artist: 'Artur Aravidi',             src: asset('audio/artur_aravidi_music-dark-synthwave-strange-time-317273.mp3') },
        { title: 'Calm Space',                artist: 'Clavier',                   src: asset('audio/clavier-music-calm-space-music-312291.mp3') },
        { title: 'Interstellar',              artist: 'Elisaveta Stoycheva',       src: asset('audio/elisaveta_stoycheva-interstellar-355703.mp3') },
        { title: 'Cyberpunk Techno',          artist: 'HumanStudioEDM',            src: asset('audio/humanstudioedm-cyberpunk-techno-510219.mp3') },
        { title: 'Interstellar Drip II',      artist: 'lazarosv',                  src: asset('audio/lazarosv-interstellar-drip-ii-337275.mp3') },
        { title: '80s Retrowave',             artist: 'REDproductions',            src: asset('audio/redproductions-80s-retrowave-synthwave-retro-synthpop-futuristic-electro-pop-music-20596.mp3') },
        { title: 'Synth Things',              artist: 'REDproductions',            src: asset('audio/redproductions-synth-things-video-film-game-tv-music-185938.mp3') },
        { title: 'Suspense Cyberpunk',        artist: 'The Mountain',              src: asset('audio/the_mountain-suspense-cyberpunk-375986.mp3') },
    ] %}

    {% include 'user_toolbar.twig' %}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
        <div class="flash-{{ label }}">
            {{ message }}
        </div>
        {% endfor %}
    {% endfor %}

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer class="site-footer">
        <div class="site-footer-bg" style="background-image: url('{{ asset('images/slack-banner-2017.jpg') }}');"></div>
        <div class="site-footer-vignette"></div>
        <div class="site-footer-content">
            <div class="site-footer-logo" aria-label="slack.cz">
                {% include '_logo.svg.twig' %}
            </div>
            <p class="site-footer-copy">© {{ "now"|date('Y') }}</p>
        </div>
    </footer>
</body>

</html>
