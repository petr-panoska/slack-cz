<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon" href="{{ asset('images/favicon.svg') }}" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap">
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {# Self-hosted Matomo — no-op unless both env vars are set (see .env) and we're
       actually in prod, so dev/test traffic never pollutes the stats. Cookieless
       mode (disableCookies): no personal data client-side, keeps this out of the
       "needs a cookie consent banner" bucket under GDPR/ePrivacy. #}
    {% if app.environment == 'prod' and matomo_url and matomo_site_id %}
        <script>
            var _paq = window._paq = window._paq || [];
            _paq.push(['disableCookies']);
            _paq.push(['trackPageView']);
            _paq.push(['enableLinkTracking']);
            (function () {
                var u = "{{ matomo_url|e('js') }}/";
                _paq.push(['setTrackerUrl', u + 'matomo.php']);
                _paq.push(['setSiteId', '{{ matomo_site_id|e('js') }}']);
                var d = document, g = d.createElement('script'), s = d.getElementsByTagName('script')[0];
                g.async = true; g.src = u + 'matomo.js'; s.parentNode.insertBefore(g, s);
            })();
        </script>
    {% endif %}
</head>

<body>
    {% include 'user_toolbar.twig' %}

    {% set flashes = app.flashes %}
    {% if flashes is not empty %}
        <div class="container-fluid mt-2 mb-2 d-flex flex-column gap-2">
            {% for label, messages in flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ {'error': 'danger', 'success': 'success', 'warning': 'warning', 'info': 'info'}[label]|default('info') }} alert-dismissible fade show mb-0" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zavřít"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    {% endif %}

    <main>
        {% block body %}{% endblock %}
    </main>

    {% block footer %}
    <footer class="site-footer">
        <div class="site-footer-bg" style="background-image: url('{{ asset('images/slack-banner-2017.jpg') }}');"></div>
        <div class="site-footer-content">
            <div class="site-footer-logo" aria-label="slack.cz">
                <svg viewBox="0 0 1082 146" aria-hidden="true">
                    <use href="{{ asset('images/logo.svg') }}#slack-logo"/>
                </svg>
            </div>
            <p class="site-footer-copy">© {{ "now"|date('Y') }}</p>
        </div>
    </footer>
    {% endblock %}
</body>

</html>
