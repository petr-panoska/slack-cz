<header class="site-header">
    <a href="{{ path('app_index') }}" class="site-logo">
        <img src="{{ asset('images/logo.png') }}" alt="slack.cz" />
    </a>

    {# Aktivní stav per route: shoda na začátek route name. Logo nahoře je už link
       na Domů, druhá položka v navu by byla redundantní. #}
    {% set route = app.current_route|default('') %}
    <nav class="site-nav">
        <a href="{{ path('app_highline_map') }}" class="{{ (route starts with 'app_highline_map' or route == 'app_highline_detail') ? 'is-active' : '' }}">Mapa</a>
        <a href="{{ path('app_tv') }}" class="{{ route == 'app_tv' ? 'is-active' : '' }}">slackTV</a>
        <a href="{{ path('app_about') }}" class="{{ route == 'app_about' ? 'is-active' : '' }}">O projektu</a>
        <a href="{{ path('app_wiki_index') }}" class="{{ route starts with 'app_wiki_' ? 'is-active' : '' }}">Wiki</a>
        <a href="{{ path('app_docs_index') }}" class="{{ route starts with 'app_docs_' ? 'is-active' : '' }}">Docs</a>
        {% if app.user %}
            <a href="{{ path('app_highline_new') }}" class="{{ route == 'app_highline_new' ? 'is-active' : '' }}">+ Lajna</a>
        {% endif %}
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_admin_proposals') }}" class="site-nav-admin {{ route == 'app_admin_proposals' ? 'is-active' : '' }}">Návrhy</a>
            <a href="{{ path('app_data_report') }}" class="site-nav-admin {{ route == 'app_data_report' ? 'is-active' : '' }}">Data report</a>
        {% endif %}
    </nav>

    <div class="site-user">
        <div
            class="site-search"
            data-controller="search"
            data-search-data-url-value="{{ path('app_highline_map_data') }}"
        >
            <button
                type="button"
                class="site-search-btn"
                data-action="click->search#toggle"
                aria-label="Hledat"
                title="Hledat"
            >
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                    <circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2"/>
                    <line x1="15.2" y1="15.2" x2="20" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
            <div class="site-search-panel">
                <input
                    type="search"
                    class="site-search-input"
                    placeholder="Najít highline…"
                    data-search-target="input"
                    data-action="input->search#input"
                    autocomplete="off"
                    spellcheck="false"
                >
                <ul class="site-search-results" data-search-target="results"></ul>
            </div>
        </div>

        {# Persistent across Turbo navigations — id+turbo-permanent keeps the audio playing through page swaps. #}
        <div
            id="music-player"
            class="intro-wrapper"
            data-controller="intro"
            data-intro-tracks-value="{{ music_tracks|json_encode }}"
            data-turbo-permanent
        >
            <div class="intro-overlay" data-intro-target="overlay">
                <div class="intro-content">
                    <img src="{{ asset('images/logo.png') }}" alt="slack.cz" class="intro-logo" />
                    <button type="button" class="intro-button" data-action="click->intro#enterSilent">Vstoupit</button>
                </div>
                <button type="button" class="intro-button intro-button--small intro-button-slackvibes" data-action="click->intro#enter">slackvibes 📻</button>
            </div>

            <aside class="music-panel panel" data-intro-target="menu" role="group" aria-label="Hudba">
                <header class="panel-header music-panel-header">
                    <div class="panel-title music-panel-title">
                        <span class="panel-dot music-panel-dot"></span>
                        <span class="music-radio-icon" aria-hidden="true">📻</span>
                        <h2 class="music-radio-name">slackvibes</h2>
                        <span class="music-eq" aria-hidden="true">
                            <span></span>
                            <span></span>
                            <span></span>
                            <span></span>
                        </span>
                    </div>
                    <div class="music-panel-trail">
                        <div class="music-panel-actions">
                            <button
                                type="button"
                                class="music-mute"
                                data-intro-target="muteBtn"
                                data-action="click->intro#toggleMuteOrPlay"
                                aria-label="Ztlumit"
                            >
                                <span class="music-icon music-icon-on" aria-hidden="true">♪</span>
                                <span class="music-icon music-icon-off" aria-hidden="true">⊘</span>
                                <span class="music-icon music-icon-play" aria-hidden="true">▶</span>
                                <span class="music-icon music-icon-pause" aria-hidden="true">⏸</span>
                            </button>
                            <button
                                type="button"
                                class="music-mini"
                                data-intro-target="miniBtn"
                                data-action="click->intro#toggleCompact"
                                aria-label="Rozbalit přehrávač"
                                title="Rozbalit"
                            >
                                <span class="music-mini-icon music-mini-icon-collapse" aria-hidden="true">−</span>
                                <span class="music-mini-icon music-mini-icon-expand" aria-hidden="true">+</span>
                            </button>
                        </div>
                        <button
                            type="button"
                            class="music-close"
                            data-action="click->intro#hide"
                            aria-label="Skrýt přehrávač"
                            title="Skrýt"
                        >×</button>
                    </div>
                </header>

                <div class="music-now">
                    <div class="music-now-title" data-intro-target="title">—</div>
                    <div class="music-now-artist" data-intro-target="artist"></div>

                    <div class="music-progress-row">
                        <input
                            type="range"
                            min="0"
                            max="1000"
                            value="0"
                            step="1"
                            class="music-progress"
                            data-intro-target="progress"
                            data-action="input->intro#seek"
                            aria-label="Pozice ve stopě"
                        >
                        <span class="music-time" data-intro-target="time">0:00 / 0:00</span>
                    </div>

                    <div class="music-controls">
                        <button type="button" class="music-ctrl music-ctrl-prev" data-action="click->intro#prev" aria-label="Předchozí">‹‹</button>
                        <button type="button" class="music-ctrl music-ctrl-play" data-intro-target="playBtn" data-action="click->intro#togglePlay" aria-label="Přehrát/Pauza">▶</button>
                        <button type="button" class="music-ctrl music-ctrl-next" data-action="click->intro#next" aria-label="Další">››</button>
                    </div>
                </div>

                <ol class="music-queue" data-intro-target="queue">
                    {% for i, t in music_tracks %}
                    <li class="music-queue-item" data-index="{{ i }}" data-action="click->intro#playIndex">
                        <span class="music-queue-num">{{ i + 1 }}</span>
                        <span class="music-queue-meta">
                            <span class="music-queue-title">{{ t.title }}</span>
                            <span class="music-queue-artist">{{ t.artist }}</span>
                        </span>
                    </li>
                    {% endfor %}
                </ol>
            </aside>
        </div>

        {% if app.user %}
            <a href="{{ path('app_profile') }}" class="user-email">{{ app.user.email }}</a>
            <form method="post" action="{{ path('app_logout') }}" class="logout-form">
                <button type="submit" class="btn btn-ghost">Odhlásit</button>
            </form>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn btn-ghost">Přihlásit</a>
            <a href="{{ path('app_register') }}" class="btn btn-primary">Registrovat</a>
        {% endif %}
    </div>
</header>
