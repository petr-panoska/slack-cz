<header class="site-header">
    <a href="{{ path('app_index') }}" class="site-logo">
        <img src="{{ asset('images/logo.png') }}" alt="slack.cz" />
    </a>

    <nav class="site-nav">
        <a href="{{ path('app_index') }}">Domů</a>
        <a href="{{ path('app_highline_map') }}">Mapa</a>
        <a href="{{ path('app_about') }}">O projektu</a>
    </nav>

    <div class="site-user">
        {% if app.user %}
            <a href="{{ path('app_profile') }}" class="user-email">{{ app.user.email }}</a>
            <form method="post" action="{{ path('app_logout') }}" class="logout-form">
                <button type="submit" class="btn btn-ghost">Odhlásit</button>
            </form>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn btn-ghost">Přihlásit</a>
            <a href="{{ path('app_register') }}" class="btn btn-primary">Registrovat</a>
        {% endif %}
    </div>
</header>
