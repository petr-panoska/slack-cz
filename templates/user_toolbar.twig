{# Aktivní stav per route: shoda na začátek route name. Logo je link na Domů. #}
{% set route = app.current_route|default('') %}

<nav class="navbar navbar-expand-lg fixed-top site-navbar" data-bs-theme="light">
    <div class="container-fluid">
        <a href="{{ path('app_index') }}" class="navbar-brand py-0 me-2 me-lg-4" aria-label="slack.cz">
            <img src="{{ asset('images/logo.png') }}" width="296" height="40" alt="" class="site-navbar-logo">
        </a>

        {# Pravý cluster — vždy viditelný (i na mobilu): hledání + auth + hamburger.
           order-lg-last ho na desktopu posune za nav odkazy. #}
        <div class="d-flex align-items-center gap-2 order-lg-last">
            {# Dropdown hledání jen na ≥lg — na mobilu je inline verze v offcanvasu. #}
            <div
                class="site-search d-none d-lg-flex"
                data-controller="search"
                data-search-data-url-value="{{ path('app_line_map_data') }}"
            >
                <button
                    type="button"
                    class="site-search-btn"
                    data-action="click->search#toggle"
                    aria-label="Hledat"
                    title="Hledat"
                >
                    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                        <circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2"/>
                        <line x1="15.2" y1="15.2" x2="20" y2="20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </button>
                <div class="site-search-panel">
                    <input
                        type="search"
                        class="site-search-input"
                        placeholder="Hledat lajnu..."
                        data-search-target="input"
                        data-action="input->search#input"
                        autocomplete="off"
                        spellcheck="false"
                    >
                    <ul class="site-search-results" data-search-target="results"></ul>
                </div>
            </div>

            {% if app.user %}
                <div class="dropdown site-user-menu d-none d-lg-block">
                    <button
                        class="btn btn-sm btn-hollow site-user-menu__toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        aria-label="Otevřít uživatelské menu"
                    >
                        <span class="site-user-menu__avatar" aria-hidden="true">{{ app.user.emoji ?? '👤' }}</span>
                        <span class="site-user-menu__label">{{ app.user.nick }}</span>   
                        <svg class="site-user-menu__chevron" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end site-user-menu__menu">
                        <li>
                            <a class="dropdown-item" href="{{ path('app_user_diary', {'id': app.user.id}) }}">
                                <span class="site-user-menu__icon" aria-hidden="true">
                                    <svg viewBox="0 0 20 20" fill="none">
                                        <path d="M10 10.5C8.07 10.5 6.5 8.93 6.5 7C6.5 5.07 8.07 3.5 10 3.5C11.93 3.5 13.5 5.07 13.5 7C13.5 8.93 11.93 10.5 10 10.5ZM4 15.5C4.95 13.8 6.82 12.75 10 12.75C13.18 12.75 15.05 13.8 16 15.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                                    </svg>
                                </span>
                                <span>Profil</span>
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form method="post" action="{{ path('app_logout') }}" class="m-0">
                                <button type="submit" class="dropdown-item site-user-menu__logout">
                                    <span class="site-user-menu__icon" aria-hidden="true">
                                        <svg viewBox="0 0 20 20" fill="none">
                                            <path d="M7.5 5.5H6.25C5.56 5.5 5 6.06 5 6.75V13.25C5 13.94 5.56 14.5 6.25 14.5H7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                                            <path d="M8.5 10H14.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                                            <path d="M13 7.75L15.25 10L13 12.25" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </span>
                                    <span>Odhlásit se</span>
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-sm btn-primary d-none d-lg-inline-flex">Přihlásit</a>
            {% endif %}

            <button
                class="navbar-toggler border-0 p-1"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#mainNav"
                aria-controls="mainNav"
                aria-label="Menu"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>

        {# Nav odkazy — offcanvas overlay na mobilu, inline na ≥lg. #}
        <div class="offcanvas offcanvas-end" tabindex="-1" id="mainNav" aria-labelledby="mainNavLabel">
            <div class="offcanvas-header">
                <h2 class="offcanvas-title h5 mb-0" id="mainNavLabel">Menu</h2>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Zavřít"></button>
            </div>
            <div class="offcanvas-body">
                {# Inline hledání (mobil) — bez toggle tlačítka, input + výsledky přímo v menu.
                   Druhá instance search controlleru; data cache je sdílená (module scope). #}
                <div
                    class="site-search site-search--inline d-lg-none mb-3"
                    data-controller="search"
                    data-search-data-url-value="{{ path('app_line_map_data') }}"
                >
                    <input
                        type="search"
                        class="site-search-input"
                        placeholder="Hledat lajnu..."
                        data-search-target="input"
                        data-action="input->search#input"
                        autocomplete="off"
                        spellcheck="false"
                    >
                    <ul class="site-search-results" data-search-target="results"></ul>
                </div>

                <ul class="navbar-nav me-auto align-items-lg-center column-gap-lg-1">
                    <li class="nav-item"><a href="{{ path('app_line_map') }}" class="nav-link {{ (route starts with 'app_line_map' or route == 'app_line_detail') ? 'active' }}">Mapa</a></li>
                    <li class="nav-item"><a href="{{ path('app_user_directory') }}" class="nav-link {{ route starts with 'app_user_' ? 'active' }}">Deníčky</a></li>
                    <li class="nav-item"><a href="{{ path('app_gallery') }}" class="nav-link {{ route == 'app_gallery' ? 'active' }}">Galerie</a></li>
                    <li class="nav-item"><a href="{{ path('app_tv') }}" class="nav-link {{ route == 'app_tv' ? 'active' }}">slackTV</a></li>
                    <li class="nav-item"><a href="{{ path('app_wiki_index') }}" class="nav-link {{ route starts with 'app_wiki_' ? 'active' }}">Wiki</a></li>
                    <li class="nav-item"><a href="{{ path('app_about') }}" class="nav-link {{ route == 'app_about' ? 'active' }}">O projektu</a></li>
                    {% if app.user %}
                        <li class="nav-item"><a href="{{ path('app_line_new') }}" class="nav-link {{ route == 'app_line_new' ? 'active' }}">+ Lajna</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item"><a href="{{ path('app_admin_proposals') }}" class="nav-link {{ route == 'app_admin_proposals' ? 'active' }}">Návrhy</a></li>
                        <li class="nav-item"><a href="{{ path('app_data_report') }}" class="nav-link {{ route == 'app_data_report' ? 'active' }}">Data report</a></li>
                    {% endif %}
                </ul>

                {% if app.user %}
                    <div class="d-lg-none border-top pt-3 mt-3">
                        <a href="{{ path('app_user_diary', {'id': app.user.id}) }}" class="btn btn-sm btn-hollow mb-2">
                            <span class="" aria-hidden="true">{{ app.user.emoji ?? '👤' }}</span>
                            <span class="text-truncate">{{ app.user.nick }}</span>
                        </a>
                        <form method="post" action="{{ path('app_logout') }}" class="m-0">
                            <button type="submit" class="btn btn-sm btn-primary">Odhlásit</button>
                        </form>
                    </div>
                {% else %}
                    <div class="d-lg-none border-top pt-3 mt-3">
                        <a href="{{ path('app_login') }}" class="btn btn-sm btn-primary">Přihlásit</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</nav>
