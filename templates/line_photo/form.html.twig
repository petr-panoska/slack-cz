{% extends 'base.html.twig' %}

{% block title %}Přidat fotku – {{ line.name }} – slack.cz{% endblock %}

{% block body %}
<article class="hl-form-page">
    <header class="hl-form-page-header">
        <a href="{{ path('app_line_detail', { slug: line.slug }) }}" class="hl-back">← {{ line.name }}</a>
        <h1>Přidat fotku</h1>
    </header>

    <section class="panel">
        {{ form_start(form, { attr: { enctype: 'multipart/form-data', novalidate: 'novalidate' } }) }}
        <div class="form-row">
            {{ form_row(form.file) }}
        </div>
        <div class="form-row">
            {{ form_row(form.caption) }}
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Nahrát</button>
            <a href="{{ path('app_line_detail', { slug: line.slug }) }}" class="btn btn-secondary">Zrušit</a>
        </div>
        <p class="form-hint">JPG, PNG nebo WebP, max 4 MB. Z fotky odstraníme EXIF (vč. GPS) a srovnáme orientaci.</p>
        {{ form_end(form) }}
    </section>
</article>
{% endblock %}
