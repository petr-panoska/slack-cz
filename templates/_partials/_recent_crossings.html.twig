{# Renders a list of recent highline crossings.
   Params:
     crossings    – iterable of HighlineCrossing
     layout       – 'panel' (default, vertical list) or 'stripe' (horizontal scroll)
     show_line    – include the highline name (default true). Set false on a highline detail page where it's redundant.
     show_user    – include the crossing author's name (default true). Set false on a user's own deník where it's redundant.
     show_actions – render edit/delete buttons next to crossings owned by the current user. Set true on the user's own deník. #}
{% set layout = layout|default('panel') %}
{% set show_line = show_line ?? true %}
{% set show_user = show_user ?? true %}
{% set show_actions = show_actions ?? false %}
{% if crossings|length > 0 %}
<ul class="crossings-list crossings-list-{{ layout }}">
    {% for c in crossings %}
        <li class="crossings-item{% if not show_line %} crossings-item-noline{% endif %}{% if not show_user %} crossings-item-nouser{% endif %}">
            <time datetime="{{ c.crossedAt|date('c') }}" class="crossings-date">{{ c.crossedAt|date('j. n. Y') }}</time>
            {% if c.style %}
                <span class="crossings-style" title="Styl přechodu">{{ c.style.label }}</span>
            {% endif %}
            {% if show_user %}
                <a class="crossings-user" href="{{ path('app_user_denik', { id: c.user.id }) }}">{{ c.user.displayName }}</a>
            {% endif %}
            <span class="crossings-rating" aria-label="hodnocení {{ c.rating ?? '–' }} z 5">
                {% if c.rating %}
                    {% for s in 1..5 %}
                        <span class="crossings-star{% if s <= c.rating %} on{% endif %}">★</span>
                    {% endfor %}
                {% else %}
                    <span class="crossings-rating-none">–</span>
                {% endif %}
            </span>
            {% if show_line %}
                <a class="crossings-line" href="{{ path('app_highline_detail', { slug: c.highline.slug }) }}">{{ c.highline.name }}</a>
            {% endif %}
            {% if c.comment %}
                <p class="crossings-comment">{{ c.comment }}</p>
            {% endif %}
            {% if show_actions and app.user and c.user.id == app.user.id %}
                <div class="crossings-actions">
                    <a class="crossings-action crossings-action-edit" href="{{ path('app_crossing_edit', { id: c.id }) }}" title="Upravit přechod">Upravit</a>
                    <form method="post" action="{{ path('app_crossing_delete', { id: c.id }) }}" class="crossings-delete-form" onsubmit="return confirm('Opravdu smazat tento přechod?');" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-crossing-' ~ c.id) }}">
                        <button type="submit" class="crossings-action crossings-action-delete" title="Smazat přechod">Smazat</button>
                    </form>
                </div>
            {% endif %}
        </li>
    {% endfor %}
</ul>
{% endif %}
