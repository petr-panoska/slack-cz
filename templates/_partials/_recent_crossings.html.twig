{# Vykreslí seznam posledních přechodů (libovolný typ lajny — Bootstrap
   list-group, má sedět zarovnaně uvnitř .card).
   Parametry:
     crossings    – iterovatelný seznam LineCrossing
     show_line    – zobrazit název lajny (default true). Vypnuto na detailu lajny, kde by bylo nadbytečné.
     show_user    – zobrazit jméno autora přechodu (default true). Vypnuto ve vlastním deníku, kde by bylo nadbytečné.
     show_actions – vykreslit tlačítka upravit/smazat u přechodů patřících aktuálnímu userovi. Zapnuto ve vlastním deníku. #}
{% set show_line = show_line ?? true %}
{% set show_user = show_user ?? true %}
{% set show_actions = show_actions ?? false %}
{% if crossings|length > 0 %}
<ul class="list-group list-group-flush">
    {% for c in crossings %}
        <li class="list-group-item crossing-item{% if not show_line %} crossing-item--noline{% endif %}{% if not show_user %} crossing-item--nouser{% endif %}">
            <time datetime="{{ c.crossedAt|date('c') }}" class="crossing-date">{{ c.crossedAt|date('j. n. Y') }}</time>
            {% if c.style %}
                <span class="badge crossing-style" title="Styl přechodu">{{ c.style.label }}</span>
            {% endif %}
            {% if show_user %}
                <a class="crossing-user" href="{{ path('app_user_diary', { id: c.user.id }) }}">{{ c.user.displayName }}</a>
            {% endif %}
            <span class="crossing-rating" aria-label="hodnocení {{ c.rating ?? '–' }} z 5">
                {% if c.rating %}
                    {% for s in 1..5 %}
                        <span class="crossing-star{% if s <= c.rating %} on{% endif %}">★</span>
                    {% endfor %}
                {% else %}
                    <span>–</span>
                {% endif %}
            </span>
            {% if show_line %}
                <a class="crossing-line" href="{{ path('app_line_detail', { slug: c.line.slug }) }}">{{ c.line.name }}</a>
            {% endif %}
            {% if c.comment %}
                <p class="crossing-comment">{{ c.comment }}</p>
            {% endif %}
            {% if show_actions and app.user and c.user.id == app.user.id %}
                <div class="crossing-actions">
                    <a class="btn btn-outline-secondary btn-sm" href="{{ path('app_crossing_edit', { id: c.id }) }}" title="Upravit přechod">Upravit</a>
                    <form method="post" action="{{ path('app_crossing_delete', { id: c.id }) }}" class="d-inline m-0" onsubmit="return confirm('Opravdu smazat tento přechod?');" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-crossing-' ~ c.id) }}">
                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Smazat přechod">Smazat</button>
                    </form>
                </div>
            {% endif %}
        </li>
    {% endfor %}
</ul>
{% endif %}
