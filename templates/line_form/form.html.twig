{% extends 'base.html.twig' %}

{% block title %}{{ mode == 'edit' ? 'Upravit lajnu' : 'Nová lajna' }} – slack.cz{% endblock %}

{% block body %}
<div class="container-xl my-4">
    <div class="card">
        <div class="card-body p-4">
            {% if mode == 'edit' %}
                <a class="hl-back" href="{{ path('app_line_detail', { slug: line.slug }) }}">← {{ line.name }}</a>
            {% else %}
                <a class="hl-back" href="{{ path('app_line_map') }}">← Mapa</a>
            {% endif %}
            <h1 class="h4 mb-4">{{ mode == 'edit' ? 'Upravit lajnu' : 'Nová lajna' }}</h1>

            {% if queueProposal %}
                <div class="form-notice">
                    Změny u téhle lajny jdou přes schválení adminem → tvůj návrh uvidí admin a po schválení se projeví na detailu.
                </div>
            {% endif %}

            {{ form_errors(form) }}

            {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
                {% if mode == 'edit' and not line.isVerified %}
                    <div
                        class="hl-form-url-panel"
                        data-controller="live-slug"
                        data-live-slug-name-input-value="{{ form.name.vars.id }}"
                    >
                        <span class="hl-form-url-label">URL lajny</span>
                        <code class="hl-form-url" data-live-slug-target="urlPath">/lajna/{{ line.slug }}</code>
                        <span class="hl-form-url-hint">Lajna ještě není verifikovaná — při změně názvu se aktualizuje i URL.</span>
                    </div>
                {% endif %}
                <div class="form-section">
                    <h2>Základní info</h2>
                    <div class="mb-3">
                        <label class="form-label" for="{{ form.name.vars.id }}">
                            Název{% if line.isVerified %} <span class="hl-form-lock" tabindex="0" aria-label="Název je pevný" title="URL: /lajna/{{ line.slug }}&#10;Název je pevný, aby existující odkazy nepřestaly fungovat.">🔒</span>{% endif %}
                        </label>
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>
                    {{ form_row(form.nameHistory) }}
                    {{ form_row(form.firstAscentBy) }}
                    {{ form_row(form.firstAscentDate) }}
                    <div class="row">
                        <div class="col-sm-12 col-md-4">{{ form_row(form.type) }}</div>
                        <div class="col-sm-12 col-md-4">{{ form_row(form.approachMinutes) }}</div>
                        <div class="col-sm-12 col-md-4">{{ form_row(form.tensioningMinutes) }}</div>
                    </div>
                    {{ form_row(form.description) }}
                </div>

                <div class="form-section">
                    <h2>Poloha</h2>
                    <div
                        class="hl-form-map"
                        data-controller="line-form-map"
                        data-line-form-map-p1-lat-input-value="{{ form.point1Latitude.vars.id }}"
                        data-line-form-map-p1-lng-input-value="{{ form.point1Longitude.vars.id }}"
                        data-line-form-map-p2-lat-input-value="{{ form.point2Latitude.vars.id }}"
                        data-line-form-map-p2-lng-input-value="{{ form.point2Longitude.vars.id }}"
                        data-line-form-map-parking-lat-input-value="{{ form.parkingLatitude.vars.id }}"
                        data-line-form-map-parking-lng-input-value="{{ form.parkingLongitude.vars.id }}"
                        data-line-form-map-init-lat-value="{{ form.point1Latitude.vars.value ?: '50.0598' }}"
                        data-line-form-map-init-lng-value="{{ form.point1Longitude.vars.value ?: '14.4656' }}"
                        data-line-form-map-length-output-value="line-length-output"
                    >
                        <div class="hl-form-map-canvas" data-line-form-map-target="canvas"></div>
                        <div class="hl-form-map-overlay">
                            <button
                                type="button"
                                class="btn btn-outline-secondary btn-sm hl-form-map-toggle"
                                data-line-form-map-target="p1Toggle"
                                data-action="click->line-form-map#toggle"
                                data-line-form-map-mode-param="p1"
                            >Přidat bod 1</button>
                            <button
                                type="button"
                                class="btn btn-outline-secondary btn-sm hl-form-map-toggle"
                                data-line-form-map-target="p2Toggle"
                                data-action="click->line-form-map#toggle"
                                data-line-form-map-mode-param="p2"
                            >Přidat bod 2</button>
                            <button
                                type="button"
                                class="btn btn-outline-secondary btn-sm hl-form-map-toggle hl-form-parking-toggle"
                                data-line-form-map-target="parkingToggle"
                                data-action="click->line-form-map#toggle"
                                data-line-form-map-mode-param="parking"
                            >Přidat parkování</button>
                        </div>
                        <div class="hl-form-map-controls-bl">
                            <button
                                type="button"
                                class="btn btn-outline-secondary btn-sm hl-form-map-btn hl-form-fullscreen-toggle"
                                data-line-form-map-target="fullscreenToggle"
                                data-action="click->line-form-map#toggleFullscreen"
                            >⛶ Celá obrazovka</button>
                        </div>
                        <div class="hl-form-distance">
                            <span class="hl-form-distance-label">Délka</span>
                            <span class="hl-form-distance-value is-empty" data-line-form-map-target="distance">Nastav oba body</span>
                        </div>
                    </div>
                    <p class="form-text mb-3">Délka se počítá automaticky ze zadaných bodů.</p>
                    <div class="row">
                        <div class="col-sm-12 col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="line-length-output">Délka [m]</label>
                                <output id="line-length-output" class="form-control-plaintext">{{ line.length ? line.length ~ ' m' : 'Nastav oba body' }}</output>
                            </div>
                        </div>
                        <div class="col-sm-12 col-md-6">{{ form_row(form.height) }}</div>
                    </div>
                    <div class="hl-form-points">
                        <div class="hl-form-point">
                            <h3>Bod 1</h3>
                            <div class="row">
                                <div class="col-sm-6">{{ form_row(form.point1Latitude) }}</div>
                                <div class="col-sm-6">{{ form_row(form.point1Longitude) }}</div>
                            </div>
                            {{ form_row(form.pointOneInfo) }}
                        </div>
                        <div class="hl-form-point">
                            <h3>Bod 2</h3>
                            <div class="row">
                                <div class="col-sm-6">{{ form_row(form.point2Latitude) }}</div>
                                <div class="col-sm-6">{{ form_row(form.point2Longitude) }}</div>
                            </div>
                            {{ form_row(form.pointTwoInfo) }}
                        </div>
                    </div>
                    <div class="hl-form-points">
                        <div class="hl-form-point hl-form-point-parking">
                            <h3>Parkování <span class="hl-form-optional">(volitelné)</span></h3>
                            <div class="row">
                                <div class="col-sm-6">{{ form_row(form.parkingLatitude) }}</div>
                                <div class="col-sm-6">{{ form_row(form.parkingLongitude) }}</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    {% if mode == 'edit' and line.coverPhoto %}
                        <img
                            class="line-cover-preview"
                            src="{{ vich_uploader_asset(line.coverPhoto, 'file') | imagine_filter('line_thumb') }}"
                            alt=""
                        >
                        <p class="form-text mb-3">Nahráním nové fotky se tahle nahradí.</p>
                    {% endif %}
                    {{ form_row(form.coverPhotoFile) }}
                </div>

                <div class="form-section">
                    <label class="form-label d-block">Hodnocení</label>
                    {{ include('_partials/_rating_picker.html.twig', { field: form.rating }) }}
                    {{ form_errors(form.rating) }}
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        {% if queueProposal %}Odeslat návrh
                        {% elseif mode == 'edit' %}Uložit
                        {% else %}Přidat lajnu{% endif %}
                    </button>
                    {% if mode == 'edit' %}
                        <a class="btn btn-outline-secondary" href="{{ path('app_line_detail', { slug: line.slug }) }}">Zrušit</a>
                    {% else %}
                        <a class="btn btn-outline-secondary" href="{{ path('app_line_map') }}">Zrušit</a>
                    {% endif %}
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
