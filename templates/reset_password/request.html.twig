{% extends 'base.html.twig' %}

{% block title %}Obnova hesla{% endblock %}

{% block body %}
    <div class="auth-page">
        <div class="auth-card">
            <h1>Obnova hesla</h1>

            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="auth-alert" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {{ form_start(requestForm) }}
                <div class="form-group">
                    {{ form_label(requestForm.email, 'Email') }}
                    {{ form_widget(requestForm.email) }}
                    {{ form_errors(requestForm.email) }}
                </div>

                <small class="auth-help">
                    Zadej email, na který je účet registrovaný — pošleme ti odkaz pro nastavení nového hesla.
                </small>

                <button type="submit">Poslat odkaz</button>
            {{ form_end(requestForm) }}

            <div class="auth-links">
                <a href="{{ path('app_login') }}">Zpět na přihlášení</a>
                <a href="{{ path('app_register') }}">Vytvořit účet</a>
            </div>
        </div>
    </div>
{% endblock %}
