{% extends 'base.html.twig' %}

{% block title %}Nové heslo{% endblock %}

{% block body %}
    <div class="auth-page">
        <div class="auth-card">
            <h1>Nastav nové heslo</h1>

            {{ form_start(resetForm) }}
                <div class="form-group">
                    {{ form_label(resetForm.password.plainPassword.first, 'Nové heslo') }}
                    {{ form_widget(resetForm.password.plainPassword.first) }}
                    {{ form_errors(resetForm.password.plainPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(resetForm.password.plainPassword.second, 'Heslo znovu') }}
                    {{ form_widget(resetForm.password.plainPassword.second) }}
                    {{ form_errors(resetForm.password.plainPassword.second) }}
                </div>

                {{ form_errors(resetForm) }}

                <button type="submit">Uložit heslo</button>
            {{ form_end(resetForm) }}
        </div>
    </div>
{% endblock %}
