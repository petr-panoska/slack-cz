{% extends 'base.html.twig' %}

{% block title %}Přihlášení{% endblock %}

{% block body %}
    <div class="form-page">
        <div class="card">
            <div class="card-body p-4">
                <h1 class="h4 mb-4">Přihlášení</h1>

                {% if app.user %}
                    <div class="alert alert-secondary">
                        Jsi přihlášen jako <strong>{{ app.user.userIdentifier }}</strong>.
                        <a href="{{ path('app_logout') }}">Odhlásit se</a>
                    </div>
                {% endif %}

                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label" for="username">Email</label>
                        <input type="email" class="form-control" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="password">Heslo</label>
                        <input type="password" class="form-control" name="_password" id="password" autocomplete="current-password" required>
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="btn btn-primary w-100">Přihlásit se</button>
                </form>

                <div class="d-flex justify-content-center small mt-4 pt-3 border-top">
                    <a href="{{ path('app_forgot_password_request') }}">Zapomenuté heslo</a>
                </div>

                <p class="mt-3 mb-0 text-center">
                    Nemáte účet? <a href="{{ path('app_register') }}">Registrujte se</a>.
                </p>
            </div>
        </div>
    </div>
{% endblock %}
