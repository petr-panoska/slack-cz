{% extends 'base.html.twig' %}

{% block title %}Registrace{% endblock %}

{% block body %}
    <div class="form-page">
        <div class="card">
            <div class="card-body p-4">
                <h1 class="h4 mb-4">Registrace</h1>

                {% for flash_error in app.flashes('verify_email_error') %}
                    <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
                {% endfor %}

                {{ form_errors(registrationForm) }}

                {{ form_start(registrationForm) }}
                    {{ form_row(registrationForm.email, { label: 'Email' }) }}
                    {{ form_row(registrationForm.password, { label: false }) }}
                    {{ form_row(registrationForm.agreeTerms) }}

                    <button type="submit" class="btn btn-primary w-100">Vytvořit účet</button>
                {{ form_end(registrationForm) }}

                <div class="d-flex justify-content-between small mt-4 pt-3 border-top">
                    <a href="{{ path('app_login') }}">Mám účet — přihlásit</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
