{% extends 'base.html.twig' %}

{% block title %}Registrace{% endblock %}

{% block body %}
    <div class="auth-page">
        <div class="auth-card">
            <h1>Registrace</h1>

            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="auth-alert" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}
                <div class="form-group">
                    {{ form_label(registrationForm.email, 'Email') }}
                    {{ form_widget(registrationForm.email) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.password, 'Heslo') }}
                    {{ form_widget(registrationForm.password) }}
                    {{ form_errors(registrationForm.password) }}
                </div>

                <div class="form-group checkbox-row">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    {{ form_label(registrationForm.agreeTerms) }}
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="btn btn-primary btn-block">Vytvořit účet</button>
            {{ form_end(registrationForm) }}

            <div class="auth-links">
                <a href="{{ path('app_login') }}">Mám účet — přihlásit</a>
            </div>
        </div>
    </div>
{% endblock %}
