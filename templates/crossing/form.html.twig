{% extends 'base.html.twig' %}

{% block title %}{{ mode == 'edit' ? 'Upravit přechod' : 'Nový přechod' }} – {{ line.name }} – slack.cz{% endblock %}

{% block body %}
<div class="form-page form-page--md">
    <div class="card">
        <div class="card-body p-4">
            <a class="hl-back" href="{{ path('app_line_detail', { slug: line.slug }) }}">← {{ line.name }}</a>
            <h1 class="h4 mb-1">{{ mode == 'edit' ? 'Upravit přechod' : 'Nový přechod' }}</h1>
            <p class="text-body-secondary mb-4">Lajna: <strong>{{ line.name }}</strong></p>

            {{ form_errors(form) }}

            {{ form_start(form) }}
                {{ form_row(form.crossedAt) }}
                {{ form_row(form.style) }}
                <div class="mb-3">
                    <label class="form-label d-block">Hodnocení</label>
                    {{ include('_partials/_rating_picker.html.twig', { field: form.rating }) }}
                    {{ form_errors(form.rating) }}
                </div>
                {{ form_row(form.comment) }}

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary flex-fill">{{ mode == 'edit' ? 'Uložit' : 'Přidat přechod' }}</button>
                    {% if mode == 'edit' %}
                        <a class="btn btn-outline-secondary flex-fill" href="{{ path('app_user_diary', { id: crossing.user.id }) }}">Zrušit</a>
                    {% else %}
                        <a class="btn btn-outline-secondary flex-fill" href="{{ path('app_line_detail', { slug: line.slug }) }}">Zrušit</a>
                    {% endif %}
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
