{% extends 'base.html.twig' %}

{% block title %}{{ profile.displayName }} – deník – slack.cz{% endblock %}

{% block body %}
<article class="diary">
    <header class="diary-head panel">
        <div class="diary-identity">
            <h1>{{ profile.displayName }}</h1>
            {% set bits = [profile.firstName, profile.lastName]|filter(v => v)|join(' ') %}
            {% if bits %}<p class="diary-realname">{{ bits }}</p>{% endif %}
            <ul class="diary-meta">
                {% if profile.city %}<li><span class="diary-meta-label">Město</span> {{ profile.city }}</li>{% endif %}
                {% if profile.birthYear %}<li><span class="diary-meta-label">Ročník</span> {{ profile.birthYear }}</li>{% endif %}
                {% if firstCrossingDate %}
                    <li>
                        <span class="diary-meta-label">První přechod</span>
                        <time datetime="{{ firstCrossingDate|date('Y-m-d') }}">{{ firstCrossingDate|date('j. n. Y') }}</time>
                    </li>
                {% endif %}
            </ul>
        </div>
    </header>

    <div class="diary-tabs tabs" data-controller="tabs">
        <div class="tabs-list" role="tablist">
            <button type="button" class="tab" role="tab" data-tabs-target="tab" data-action="tabs#select" data-tabs-hash-param="highline" aria-selected="true">Highline deník</button>
            <button type="button" class="tab" role="tab" data-tabs-target="tab" data-action="tabs#select" data-tabs-hash-param="longline" aria-selected="false">Longline deník</button>
        </div>

        <div class="tab-panel" role="tabpanel" data-tabs-target="panel">
            <div class="diary-grid">
                <section class="panel diary-map-panel">
                    <header class="panel-header">
                        <div class="panel-title">
                            <span class="panel-dot panel-dot-map"></span>
                            <h2>Mapa <span class="hl-crossings-count">{{ mapLines|length }}</span></h2>
                        </div>
                    </header>
                    {% if mapLines|length > 0 %}
                        <div
                            class="diary-map-wrapper"
                            data-controller="user-diary-map"
                            data-user-diary-map-lines-value="{{ mapLines|json_encode|e('html_attr') }}"
                            data-user-diary-map-icon-url-value="{{ asset('images/leaflet/marker-icon.png') }}"
                            data-user-diary-map-icon-retina-url-value="{{ asset('images/leaflet/marker-icon-2x.png') }}"
                            data-user-diary-map-shadow-url-value="{{ asset('images/leaflet/marker-shadow.png') }}"
                        >
                            <div class="diary-map-canvas" data-user-diary-map-target="canvas"></div>
                        </div>
                    {% else %}
                        <p class="hl-empty">Zatím bez záznamu na mapě.</p>
                    {% endif %}
                </section>

                <section class="panel diary-crossings-panel">
                    <header class="panel-header">
                        <div class="panel-title">
                            <span class="panel-dot panel-dot-crossings"></span>
                            <h2>Přechody <span class="hl-crossings-count">{{ crossings|length }}</span></h2>
                        </div>
                    </header>
                    {% if crossings|length > 0 %}
                        {{ include('_partials/_recent_crossings.html.twig', { crossings: crossings, layout: 'panel', show_line: true, show_user: false, show_actions: true }) }}
                    {% else %}
                        <p class="hl-empty">Zatím žádný zaznamenaný přechod.</p>
                    {% endif %}
                </section>
            </div>
        </div>

        <div class="tab-panel" role="tabpanel" data-tabs-target="panel" hidden>
            <section class="panel diary-longline-panel">
                <header class="panel-header">
                    <div class="panel-title">
                        <span class="panel-dot panel-dot-crossings"></span>
                        <h2>Longline přechody <span class="hl-crossings-count">{{ longlineCrossings|length }}</span></h2>
                    </div>
                    {% if app.user and app.user.id == profile.id %}
                        <a class="btn btn-primary btn-sm" href="{{ path('app_longline_new') }}">Zapiš přechod</a>
                    {% endif %}
                </header>
                {% if longlineCrossings|length > 0 %}
                    {{ include('_partials/_longline_crossings.html.twig', { crossings: longlineCrossings, show_actions: true }) }}
                {% else %}
                    <p class="hl-empty">Zatím žádný longline přechod.</p>
                {% endif %}
            </section>
        </div>
    </div>
</article>
{% endblock %}
