{% extends 'base.html.twig' %}

{% block title %}{{ profile.displayName }} – deník – slack.cz{% endblock %}

{% block body %}
<article class="container-xl my-4">
    <header class="card mb-4">
        <div class="card-body">
            <h1 class="h3 mb-1">{{ profile.emoji}} {{ profile.displayName }}</h1>
            {% set bits = [profile.firstName, profile.lastName]|filter(v => v)|join(' ') %}
            {% if bits %}<p class="text-body-secondary mb-3">{{ bits }}</p>{% endif %}
            <ul class="list-inline mb-0 small">
                {% if profile.city %}<li class="list-inline-item me-4"><span class="meta-label">Město</span> {{ profile.city }}</li>{% endif %}
                {% if profile.birthYear %}<li class="list-inline-item me-4"><span class="meta-label">Ročník</span> {{ profile.birthYear }}</li>{% endif %}
                {# Telefon vidí jen přihlášení — komunitní sdílení kontaktu, ne veřejné. #}
                {% if app.user and profile.phone %}<li class="list-inline-item me-4"><span class="meta-label">Telefon</span> {{ profile.phone }}</li>{% endif %}
            </ul>
            {% if app.user and app.user.id == profile.id %}
            <hr>
                <p>Tohle vidíš jen Ty...</p>
                <p>Email: {{ profile.email }}</p>
                <a class="btn btn-primary btn-sm" href="{{ path('app_profile_edit') }}">Upravit profil</a>
                <a class="btn btn-outline-primary btn-sm" href="#todo">Změnit heslo</a>
            {% endif %}
        </div>
    </header>

    <div data-controller="tabs">
        <nav class="nav nav-underline mb-3" role="tablist">
            <button type="button" class="nav-link active" role="tab" data-tabs-target="tab" data-action="tabs#select" data-tabs-hash-param="denik" aria-selected="true">Deník</button>
            <button type="button" class="nav-link" role="tab" data-tabs-target="tab" data-action="tabs#select" data-tabs-hash-param="longline" aria-selected="false">Longline deník</button>
        </nav>

        <div role="tabpanel" data-tabs-target="panel">
            {% if profile.id == app.user.id %}
                <div class="alert alert-primary" role="alert">🛈 Přechod zapíšeš v detailu konkrétní lajny. Mrkni do <a href="{{ path('app_line_map') }}">mapy</a>.</div>
            {% endif %}
            <div class="row g-4 align-items-start">
                <div class="col-lg-6">
                    <section class="card overflow-hidden">
                        <header class="card-header">
                            <div class="d-flex align-items-center gap-2">
                                <span class="card-dot card-dot-map"></span>
                                <h2>Mapa <span class="count-badge">{{ mapLines|length }}</span></h2>
                            </div>
                        </header>
                        {% if mapLines|length > 0 %}
                            <div
                                class="diary-map-wrapper"
                                data-controller="user-diary-map"
                                data-user-diary-map-lines-value="{{ mapLines|json_encode|e('html_attr') }}"
                                data-user-diary-map-icon-url-value="{{ asset('images/leaflet/marker-icon.png') }}"
                                data-user-diary-map-icon-retina-url-value="{{ asset('images/leaflet/marker-icon-2x.png') }}"
                                data-user-diary-map-shadow-url-value="{{ asset('images/leaflet/marker-shadow.png') }}"
                            >
                                <div class="diary-map-canvas" data-user-diary-map-target="canvas"></div>
                            </div>
                        {% else %}
                            <p class="text-body-secondary fst-italic p-3 mb-0">Zatím bez záznamu na mapě.</p>
                        {% endif %}
                    </section>
                </div>

                <div class="col-lg-6">
                    <section class="card">
                        <header class="card-header">
                            <div class="d-flex align-items-center gap-2">
                                <span class="card-dot card-dot-crossings"></span>
                                <h2>Přechody <span class="count-badge">{{ crossings|length }}</span></h2>
                            </div>
                        </header>
                        {% if crossings|length > 0 %}
                            {{ include('_partials/_recent_crossings.html.twig', { crossings: crossings, show_line: true, show_user: false, show_actions: true }) }}
                        {% else %}
                            <p class="text-body-secondary fst-italic p-3 mb-0">Zatím žádný zaznamenaný přechod.</p>
                        {% endif %}
                    </section>
                </div>
            </div>
        </div>

        <div role="tabpanel" data-tabs-target="panel" hidden>
            <section class="card">
                <header class="card-header">
                    <div class="d-flex align-items-center gap-2">
                        <span class="card-dot card-dot-crossings"></span>
                        <h2>Longline přechody <span class="count-badge">{{ longlineCrossings|length }}</span></h2>
                    </div>
                    {% if app.user and app.user.id == profile.id %}
                        <a class="btn btn-primary btn-sm" href="{{ path('app_longline_new') }}">Zapiš přechod</a>
                    {% endif %}
                </header>
                {% if longlineCrossings|length > 0 %}
                    {{ include('_partials/_longline_crossings.html.twig', { crossings: longlineCrossings, show_actions: true }) }}
                {% else %}
                    <p class="text-body-secondary fst-italic p-3 mb-0">Zatím žádný longline přechod.</p>
                {% endif %}
            </section>
        </div>
    </div>
</article>
{% endblock %}
