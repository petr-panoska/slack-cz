{% extends 'base.html.twig' %}

{% block title %}Wiki — Highline guidebook — slack.cz{% endblock %}

{% block body %}
<article class="article wiki-show">
    {% if readme is null %}
        <p class="wiki-empty">
            Wiki je momentálně nedostupná (GitHub neodpovídá a nemáme uložený poslední dobrý stav). Zkus to za chvíli.
        </p>
    {% else %}
        <header class="wiki-show-head">
            <div class="wiki-show-meta">
                <a href="{{ readme.githubUrl }}" target="_blank" rel="noopener" class="wiki-meta-link">
                    Zobrazit na GitHubu
                </a>
                <span class="wiki-meta-sep">·</span>
                <a href="{{ readme.githubEditUrl }}" target="_blank" rel="noopener" class="wiki-meta-link">
                    Upravit
                </a>
            </div>
        </header>

        <div class="wiki-layout">
            <aside class="wiki-sidebar">
                {% set lastGroup = null %}
                <ul class="wiki-sidebar-list">
                    <li>
                        <a href="{{ path('app_wiki_index') }}" class="wiki-sidebar-link is-active">README.md</a>
                    </li>
                    {% for entry in entries %}
                        {% if entry.group != lastGroup %}
                            </ul><ul class="wiki-sidebar-list">
                            <li class="wiki-sidebar-group">{{ entry.group }}</li>
                            {% set lastGroup = entry.group %}
                        {% endif %}
                        <li>
                            <a
                                href="{{ path('app_wiki_show', {slug: entry.slug}) }}"
                                class="wiki-sidebar-link"
                            >{{ entry.title }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </aside>

            <div class="wiki-prose">
                {{ body_html|raw }}
            </div>
        </div>
    {% endif %}
</article>
{% endblock %}
