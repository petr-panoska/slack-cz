{% extends 'base.html.twig' %}

{% block title %}slack.cz{% endblock %}

{% block body %}
<div class="page-grid">
    <div class="page-main">
        <section
            class="panel panel-hpmap"
            data-controller="hp-map"
            data-hp-map-icon-url-value="{{ asset('images/leaflet/marker-icon.png') }}"
            data-hp-map-icon-retina-url-value="{{ asset('images/leaflet/marker-icon-2x.png') }}"
            data-hp-map-shadow-url-value="{{ asset('images/leaflet/marker-shadow.png') }}"
        >
            <header class="panel-header">
                <div class="panel-title">
                    <span class="panel-dot panel-dot-map"></span>
                    <h2>Mapa</h2>
                </div>
                <a href="{{ path('app_line_map') }}" class="panel-link">Otevřít →</a>
            </header>
            <div class="hp-map-body">
                <aside class="hp-crossings" aria-label="Poslední přechody">
                    {% if recent_crossings|length > 0 %}
                    <ul class="crossings-list crossings-list-panel">
                        {% for c in recent_crossings %}
                        <li
                            class="crossings-item hp-crossing{{ loop.first ? ' is-active' : '' }}"
                            data-hp-map-target="item"
                            data-action="click->hp-map#select"
                            data-name="{{ c.line.name }}"
                            data-lat="{{ c.line.latitude }}"
                            data-lng="{{ c.line.longitude }}"
                            data-p1-lat="{{ c.line.point1Latitude }}"
                            data-p1-lng="{{ c.line.point1Longitude }}"
                            data-p2-lat="{{ c.line.point2Latitude }}"
                            data-p2-lng="{{ c.line.point2Longitude }}"
                            data-user-id="{{ c.user.id }}"
                            data-comment="{{ c.comment }}"
                        >
                            <time datetime="{{ c.crossedAt|date('c') }}" class="crossings-date">{{ c.crossedAt|date('j. n. Y') }}</time>
                            {% if c.style %}
                                <span class="crossings-style" title="Styl přechodu">{{ c.style.label }}</span>
                            {% endif %}
                            <span class="crossings-user">{{ c.user.displayName }}</span>
                            <span class="crossings-rating" aria-label="hodnocení {{ c.rating ?? '–' }} z 5">
                                {% if c.rating %}
                                    {% for s in 1..5 %}
                                        <span class="crossings-star{% if s <= c.rating %} on{% endif %}">★</span>
                                    {% endfor %}
                                {% else %}
                                    <span class="crossings-rating-none">–</span>
                                {% endif %}
                            </span>
                            <a class="crossings-line" href="{{ path('app_line_detail', { slug: c.line.slug }) }}">{{ c.line.name }}</a>
                        </li>
                        {% endfor %}
                    </ul>
                    {% else %}
                    <p class="hp-crossings-empty">Zatím žádný přechod.</p>
                    {% endif %}
                </aside>
                <div class="hp-map-canvas-wrap">
                    <div class="hp-map-canvas" data-hp-map-target="canvas"></div>
                </div>
            </div>
        </section>

        {% if recent_photos|length > 0 %}
        <aside class="panel panel-photos">
            <header class="panel-header">
                <div class="panel-title">
                    <span class="panel-dot panel-dot-gallery"></span>
                    <h2>Z galerie</h2>
                </div>
            </header>
            <ul class="hp-photos-grid">
                {% for photo in recent_photos %}
                    <li class="hp-photo">
                        <a href="{{ path('app_line_photo_detail', { slug: photo.line.slug, id: photo.id }) }}" class="hp-photo-link">
                            <img
                                src="{{ vich_uploader_asset(photo, 'file') | imagine_filter('line_thumb') }}"
                                alt="{{ photo.caption ?? photo.line.name }}"
                                loading="lazy"
                                decoding="async"
                                width="320"
                                height="240"
                            >
                            <span class="hp-photo-overlay">
                                <span class="hp-photo-line">{{ photo.line.name }}</span>
                                {% if photo.uploadedBy %}
                                    <span class="hp-photo-author">{{ photo.uploadedBy.displayName }}</span>
                                {% endif %}
                            </span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </aside>
        {% endif %}
    </div>

    {% if feed_items|length > 0 %}
    <aside class="panel panel-tv panel-tv-strip">
        <header class="panel-header">
            <div class="panel-title">
                <span class="panel-dot panel-dot-tv"></span>
                <h2>slackTV</h2>
            </div>
            <a href="{{ path('app_tv') }}" class="panel-link">Otevřít →</a>
        </header>
        <ul class="tv-strip">
            {% for item in feed_items %}
            <li class="tv-strip-item">
                <a href="{{ item.link }}" target="_blank" rel="noopener" class="tv-thumb">
                    <img src="{{ item.thumbnailUrl }}" alt="" loading="lazy" />
                    <span class="tv-play" aria-hidden="true">▶</span>
                </a>
                <div class="tv-meta">
                    <h3 class="tv-title">
                        <a href="{{ item.link }}" target="_blank" rel="noopener">{{ item.title }}</a>
                    </h3>
                    <div class="tv-sub">
                        {% if item.authorUrl %}
                            <a href="{{ item.authorUrl }}" target="_blank" rel="noopener">{{ item.authorName }}</a>
                        {% else %}
                            <span>{{ item.authorName }}</span>
                        {% endif %}
                        <span class="tv-sep">·</span>
                        <time datetime="{{ item.publishedAt|date('c') }}">{{ item.publishedAt|date('j. n. Y') }}</time>
                    </div>
                </div>
            </li>
            {% endfor %}
        </ul>
    </aside>
    {% endif %}
</div>
{% endblock %}
