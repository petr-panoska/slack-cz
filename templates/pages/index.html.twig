{% extends 'base.html.twig' %}

{% block title %}slack.cz{% endblock %}

{% block body %}
{% set music_tracks = [
    { title: 'Dark Wave 80s Retro Vibes', artist: 'nickpanekAIassets', src: asset('audio/intro-1-dark.mp3') },
    { title: 'Neonscapes',                artist: 'FSM Team feat. <e s c p>', src: asset('audio/intro-2-chill.mp3') },
    { title: 'Cyber Thriller',            artist: 'FSM Team feat. <e s c p>', src: asset('audio/intro-3-driving.mp3') },
    { title: 'Magenta Metropolis',        artist: 'FSM Team feat. <e s c p>', src: asset('audio/intro-4-cinematic.mp3') },
] %}

<div
    class="intro-wrapper"
    data-controller="intro"
    data-intro-tracks-value="{{ music_tracks|json_encode }}"
>
    <div class="intro-overlay" data-intro-target="overlay">
        <div class="intro-content">
            <button type="button" class="intro-button" data-action="click->intro#enter">Vstoupit</button>
            <p class="intro-tagline">Highline · Midline · Urbanline</p>
        </div>
    </div>

    <div class="music-menu" data-intro-target="menu" role="group" aria-label="Hudba">
        <button
            type="button"
            class="music-btn music-mute"
            data-intro-target="muteBtn"
            data-action="click->intro#toggleMute"
            aria-label="Ztlumit"
            aria-pressed="false"
        >
            <span class="music-icon music-icon-on" aria-hidden="true">♪</span>
            <span class="music-icon music-icon-off" aria-hidden="true">⊘</span>
        </button>
        <button type="button" class="music-btn" data-action="click->intro#prev" aria-label="Předchozí stopa">‹</button>
        <span class="music-label" data-intro-target="label"></span>
        <button type="button" class="music-btn" data-action="click->intro#next" aria-label="Další stopa">›</button>
    </div>
</div>

<div class="page-grid">
    <div class="page-main">
        <section class="panel panel-map">
            <header class="panel-header">
                <div class="panel-title">
                    <span class="panel-dot panel-dot-map"></span>
                    <h2>Highline mapa</h2>
                </div>
                <a href="{{ path('app_highline_map') }}" class="panel-link">Otevřít →</a>
            </header>
            <div
                class="panel-map-canvas"
                data-controller="featured-map"
                data-featured-map-data-url-value="{{ path('app_highline_map_data') }}"
                data-featured-map-crossings-url-value="{{ path('app_highline_map_recent_crossings') }}"
                data-featured-map-icon-url-value="{{ asset('images/leaflet/marker-icon.png') }}"
                data-featured-map-icon-retina-url-value="{{ asset('images/leaflet/marker-icon-2x.png') }}"
                data-featured-map-shadow-url-value="{{ asset('images/leaflet/marker-shadow.png') }}"
            ></div>
        </section>

        {% if recent_crossings|length > 0 %}
        <aside class="panel panel-crossings panel-crossings-stripe">
            <header class="panel-header">
                <div class="panel-title">
                    <span class="panel-dot panel-dot-crossings"></span>
                    <h2>Poslední přechody</h2>
                </div>
            </header>
            {{ include('_partials/_recent_crossings.html.twig', { crossings: recent_crossings, layout: 'stripe' }) }}
        </aside>
        {% endif %}
    </div>

    {% if feed_items|length > 0 %}
    <aside class="panel panel-tv">
        <header class="panel-header">
            <div class="panel-title">
                <span class="panel-dot panel-dot-tv"></span>
                <h2>Slack.cz TV</h2>
            </div>
        </header>
        <ul class="tv-list">
            {% for item in feed_items %}
            <li class="tv-item">
                <a href="{{ item.link }}" target="_blank" rel="noopener" class="tv-thumb">
                    <img src="{{ item.thumbnailUrl }}" alt="" loading="lazy" />
                    <span class="tv-play" aria-hidden="true">▶</span>
                </a>
                <div class="tv-meta">
                    <h3 class="tv-title">
                        <a href="{{ item.link }}" target="_blank" rel="noopener">{{ item.title }}</a>
                    </h3>
                    <div class="tv-sub">
                        {% if item.authorUrl %}
                            <a href="{{ item.authorUrl }}" target="_blank" rel="noopener">{{ item.authorName }}</a>
                        {% else %}
                            <span>{{ item.authorName }}</span>
                        {% endif %}
                        <span class="tv-sep">·</span>
                        <time datetime="{{ item.publishedAt|date('c') }}">{{ item.publishedAt|date('j. n. Y') }}</time>
                    </div>
                </div>
            </li>
            {% endfor %}
        </ul>
    </aside>
    {% endif %}
</div>
{% endblock %}
