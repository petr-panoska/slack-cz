{% extends 'base.html.twig' %}

{% block title %}slack.cz{% endblock %}

{% block body %}
<div class="page-grid">
    <div class="page-main">
        <section class="panel panel-map">
            <header class="panel-header">
                <div class="panel-title">
                    <span class="panel-dot panel-dot-map"></span>
                    <h2>Highline mapa</h2>
                </div>
                <a href="{{ path('app_highline_map') }}" class="panel-link">Otevřít →</a>
            </header>
            <div
                class="panel-map-wrapper"
                data-controller="map"
                data-map-data-url-value="{{ path('app_highline_map_data') }}"
                data-map-users-url-value="{{ path('app_highline_map_feed') }}"
                data-map-icon-url-value="{{ asset('images/leaflet/marker-icon.png') }}"
                data-map-icon-retina-url-value="{{ asset('images/leaflet/marker-icon-2x.png') }}"
                data-map-shadow-url-value="{{ asset('images/leaflet/marker-shadow.png') }}"
            >
                <div class="panel-map-canvas" data-map-target="canvas"></div>
            </div>
        </section>

        {% if recent_crossings|length > 0 %}
        <aside class="panel panel-crossings panel-crossings-stripe">
            <header class="panel-header">
                <div class="panel-title">
                    <span class="panel-dot panel-dot-crossings"></span>
                    <h2>Poslední přechody</h2>
                </div>
            </header>
            {{ include('_partials/_recent_crossings.html.twig', { crossings: recent_crossings, layout: 'stripe' }) }}
        </aside>
        {% endif %}

        {% if recent_photos|length > 0 %}
        <aside class="panel panel-photos">
            <header class="panel-header">
                <div class="panel-title">
                    <span class="panel-dot panel-dot-gallery"></span>
                    <h2>Z galerie</h2>
                </div>
            </header>
            <ul class="hp-photos-grid">
                {% for photo in recent_photos %}
                    <li class="hp-photo">
                        <a href="{{ path('app_highline_photo_detail', { slug: photo.highline.slug, id: photo.id }) }}" class="hp-photo-link">
                            <img
                                src="{{ vich_uploader_asset(photo, 'file') | imagine_filter('highline_thumb') }}"
                                alt="{{ photo.caption ?? photo.highline.name }}"
                                loading="lazy"
                                decoding="async"
                                width="320"
                                height="240"
                            >
                            <span class="hp-photo-overlay">
                                <span class="hp-photo-line">{{ photo.highline.name }}</span>
                                {% if photo.uploadedBy %}
                                    <span class="hp-photo-author">{{ photo.uploadedBy.displayName }}</span>
                                {% endif %}
                            </span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </aside>
        {% endif %}
    </div>

    {% if feed_items|length > 0 %}
    <aside class="panel panel-tv panel-tv-strip">
        <header class="panel-header">
            <div class="panel-title">
                <span class="panel-dot panel-dot-tv"></span>
                <h2>slackTV</h2>
            </div>
            <a href="{{ path('app_tv') }}" class="panel-link">Otevřít →</a>
        </header>
        <ul class="tv-strip">
            {% for item in feed_items %}
            <li class="tv-strip-item">
                <a href="{{ item.link }}" target="_blank" rel="noopener" class="tv-thumb">
                    <img src="{{ item.thumbnailUrl }}" alt="" loading="lazy" />
                    <span class="tv-play" aria-hidden="true">▶</span>
                </a>
                <div class="tv-meta">
                    <h3 class="tv-title">
                        <a href="{{ item.link }}" target="_blank" rel="noopener">{{ item.title }}</a>
                    </h3>
                    <div class="tv-sub">
                        {% if item.authorUrl %}
                            <a href="{{ item.authorUrl }}" target="_blank" rel="noopener">{{ item.authorName }}</a>
                        {% else %}
                            <span>{{ item.authorName }}</span>
                        {% endif %}
                        <span class="tv-sep">·</span>
                        <time datetime="{{ item.publishedAt|date('c') }}">{{ item.publishedAt|date('j. n. Y') }}</time>
                    </div>
                </div>
            </li>
            {% endfor %}
        </ul>
    </aside>
    {% endif %}
</div>
{% endblock %}
