{% extends 'base.html.twig' %}

{% block title %}Highline mapa{% endblock %}

{% block body %}
<div
    class="highline-map-wrapper"
    data-controller="map"
    data-map-data-url-value="{{ path('app_highline_map_data') }}"
    data-map-users-url-value="{{ path('app_highline_map_feed') }}"
    data-map-timeline-url-value="{{ path('app_highline_map_timeline') }}"
    data-map-icon-url-value="{{ asset('images/leaflet/marker-icon.png') }}"
    data-map-icon-retina-url-value="{{ asset('images/leaflet/marker-icon-2x.png') }}"
    data-map-shadow-url-value="{{ asset('images/leaflet/marker-shadow.png') }}"
>
    <div class="highline-map" data-map-target="canvas"></div>

    <aside
        class="crossing-feed"
        aria-label="Přechody"
        data-controller="crossing-feed"
        data-crossing-feed-url-value="{{ path('app_highline_map_feed') }}"
    >
        <header class="crossing-feed-header">
            <span class="crossing-feed-dot" aria-hidden="true"></span>
            <div class="crossing-feed-titles">
                <h2 class="crossing-feed-title">Přechody</h2>
                <button
                    type="button"
                    class="crossing-feed-caption"
                    data-crossing-feed-target="caption"
                    data-action="click->crossing-feed#toggleFilter"
                    aria-expanded="false"
                    aria-controls="crossing-feed-filter"
                    title="Změnit filtr přechodů"
                >Posledních 10 přechodů</button>
            </div>
            <button
                type="button"
                class="crossing-feed-eye"
                data-action="click->crossing-feed#toggleUsers"
                aria-label="Skrýt přechody na mapě"
                title="Skrýt přechody na mapě"
            >
                <svg class="crossing-feed-eye-on" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2.5 12s3.5-7 9.5-7 9.5 7 9.5 7-3.5 7-9.5 7S2.5 12 2.5 12z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="crossing-feed-eye-off" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 3l18 18"/>
                    <path d="M10.6 6.2A10.1 10.1 0 0 1 12 6c6 0 9.5 7 9.5 7a14.7 14.7 0 0 1-3.3 4.1"/>
                    <path d="M6.2 7.8C3.9 9.6 2.5 12 2.5 12s3.5 7 9.5 7c1.6 0 3-.4 4.2-1"/>
                    <path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"/>
                </svg>
            </button>
            <button
                type="button"
                class="crossing-feed-toggle"
                data-action="click->crossing-feed#toggle"
                aria-label="Skrýt panel"
                title="Skrýt panel"
            >
                <span class="crossing-feed-toggle-icon" aria-hidden="true">‹</span>
            </button>
        </header>
        <div
            class="crossing-feed-filter"
            id="crossing-feed-filter"
            data-crossing-feed-target="filter"
            hidden
        >
            <label class="crossing-feed-filter-row">
                <input
                    type="radio"
                    name="feed-filter-mode"
                    value="count"
                    checked
                    data-crossing-feed-target="modeCount"
                    data-action="change->crossing-feed#changeMode"
                >
                <span>Posledních</span>
                <input
                    type="number"
                    min="1"
                    max="200"
                    value="10"
                    class="crossing-feed-filter-num"
                    aria-label="Počet posledních přechodů"
                    data-crossing-feed-target="count"
                    data-action="input->crossing-feed#changeCount"
                >
                <span>přechodů</span>
            </label>
            <label class="crossing-feed-filter-row">
                <input
                    type="radio"
                    name="feed-filter-mode"
                    value="range"
                    data-crossing-feed-target="modeRange"
                    data-action="change->crossing-feed#changeMode"
                >
                <span>Rozsah dat</span>
            </label>
            <div class="crossing-feed-filter-range">
                <input
                    type="date"
                    aria-label="Datum od"
                    data-crossing-feed-target="from"
                    data-action="change->crossing-feed#changeRange"
                >
                <span aria-hidden="true">–</span>
                <input
                    type="date"
                    aria-label="Datum do"
                    data-crossing-feed-target="to"
                    data-action="change->crossing-feed#changeRange"
                >
            </div>
        </div>
        <div class="crossing-feed-body-wrap">
            <ul class="crossing-feed-list" data-crossing-feed-target="list"></ul>
            <p class="crossing-feed-empty" data-crossing-feed-target="empty" hidden>Zatím žádný přechod.</p>
        </div>
    </aside>

    <button
        type="button"
        class="map-tt-toggle"
        data-map-target="ttToggle"
        data-action="click->map#toggleTimeTravel"
    >Přehrát historii</button>

    <div class="map-tt-panel" data-map-target="ttPanel">
        <div class="map-tt-row">
            <button
                type="button"
                class="map-tt-play"
                data-map-target="ttPlay"
                data-action="click->map#togglePlay"
                aria-label="Přehrát"
            >▶</button>
            <span class="map-tt-date" data-map-target="ttDate">—</span>
            <input
                type="range"
                min="0"
                max="1000"
                value="0"
                step="1"
                class="map-tt-slider"
                data-map-target="ttSlider"
                data-action="change->map#seek"
                aria-label="Posun v čase"
            >
            <select
                class="map-tt-speed"
                data-map-target="ttSpeed"
                data-action="change->map#setSpeed"
                aria-label="Rychlost"
            >
                <option value="0.5">½×</option>
                <option value="1" selected>1×</option>
                <option value="2">2×</option>
                <option value="4">4×</option>
            </select>
        </div>
        <div class="map-tt-counter" data-map-target="ttCounter">Highlines: 0 · Přechody: 0</div>
    </div>
</div>
{% endblock %}
