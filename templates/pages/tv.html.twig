{% extends 'base.html.twig' %}

{% block title %}slackTV — slack.cz{% endblock %}

{% block body %}
<div class="tv-page">
    <header class="tv-page-header">
        <div class="d-flex align-items-center gap-2">
            <span class="card-dot card-dot-tv"></span>
            <h1>slackTV</h1>
        </div>
        <p class="tv-page-sub">Slacklinová videa z české scény. Klikni na náhled a pusť si je rovnou tady.</p>
    </header>

    {% if not (sections.channels or sections.foreignChannels or sections.playlists or sections.hashtags) %}
        <p class="tv-empty">Zatím tu nic neběží. Brzy přibydou videa.</p>
    {% else %}

        {% if sections.channels %}
        <section class="tv-section">
            <h2 class="tv-section-title">Kanály</h2>
            {% for group in sections.channels %}
                {{ include('pages/_tv_slider.html.twig', { group: group }) }}
            {% endfor %}
        </section>
        {% endif %}

        {% if sections.foreignChannels %}
        <section class="tv-section">
            <h2 class="tv-section-title">Zahraniční kanály</h2>
            {% for group in sections.foreignChannels %}
                {{ include('pages/_tv_slider.html.twig', { group: group }) }}
            {% endfor %}
        </section>
        {% endif %}

        {% if sections.playlists %}
        <section class="tv-section">
            <h2 class="tv-section-title">Playlisty</h2>
            {% for group in sections.playlists %}
                {{ include('pages/_tv_slider.html.twig', { group: group }) }}
            {% endfor %}
        </section>
        {% endif %}

        {% if sections.hashtags %}
        <section class="tv-section" data-controller="tabs">
            <h2 class="tv-section-title">Hashtagy</h2>
            <nav class="nav nav-pills flex-wrap gap-2 mt-3" role="tablist">
                {% for group in sections.hashtags %}
                <button
                    type="button"
                    class="nav-link{{ loop.first ? ' active' }}"
                    role="tab"
                    data-tabs-target="tab"
                    data-action="tabs#select"
                    aria-selected="{{ loop.first ? 'true' : 'false' }}"
                >{{ group.title }}</button>
                {% endfor %}
            </nav>
            {% for group in sections.hashtags %}
            <div class="tab-panel" role="tabpanel" data-tabs-target="panel"{{ not loop.first ? ' hidden' }}>
                {{ include('pages/_tv_slider.html.twig', { group: group, headless: true }) }}
            </div>
            {% endfor %}
        </section>
        {% endif %}

    {% endif %}
</div>
{% endblock %}
