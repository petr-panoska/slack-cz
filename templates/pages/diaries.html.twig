{% extends 'base.html.twig' %}

{% block title %}Deníčky – kdo, kde a kdy chodil – slack.cz{% endblock %}

{% block body %}
<div class="container-xl py-4">
    <header class="mb-4">
        <h1 class="mb-1">Deníčky</h1>
        <p class="text-body-secondary mb-0">Kdo, kde a kdy chodil. Klikni na nick pro celý deník, řaď přes hlavičky sloupců.</p>
    </header>

    <section class="card" data-controller="data-table">
        <header class="card-header d-flex align-items-center gap-2">
            <h2 class="h5 mb-0">Lajneři</h2>
            <span class="badge text-bg-secondary" data-data-table-target="count">{{ rows|length }}</span>
        </header>

        <div class="card-body py-2">
            <input
                type="search"
                class="form-control table-filter"
                placeholder="Hledat podle nicku nebo jména…"
                autocomplete="off"
                spellcheck="false"
                data-data-table-target="filter"
                data-action="input->data-table#filter"
            >
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col" class="cell-num" data-sort-type="date" data-sort-default="desc" data-action="click->data-table#sort" aria-sort="descending">Poslední aktivita</th>
                        <th scope="col" data-sort-type="text" data-action="click->data-table#sort">Nick</th>
                        <th scope="col" data-sort-type="text" data-action="click->data-table#sort">Jméno</th>
                        <th scope="col" class="cell-num" data-sort-type="num" data-sort-default="desc" data-action="click->data-table#sort">Highline</th>
                        <th scope="col" class="cell-num" data-sort-type="num" data-sort-default="desc" data-action="click->data-table#sort">Longline</th>
                    </tr>
                </thead>
                <tbody data-data-table-target="body">
                    {% for row in rows %}
                        {% set name = [row.firstName, row.lastName]|filter(v => v)|join(' ') %}
                        <tr data-filter="{{ (row.nick ~ ' ' ~ name)|trim }}">
                            <td class="cell-num text-body-secondary" data-sort-value="{{ row.lastActivity ? row.lastActivity|date('Y-m-d') : '' }}">
                                {% if row.lastActivity %}
                                    <time datetime="{{ row.lastActivity|date('Y-m-d') }}">{{ row.lastActivity|date('j. n. Y') }}</time>
                                {% else %}–{% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_user_diary', { id: row.id }) }}">
                                    {{ row.nick ?: 'uživatel #' ~ row.id }}
                                </a>
                            </td>
                            <td>{{ name ?: '–' }}</td>
                            <td class="cell-num text-body-secondary">{{ row.highlineCount }}</td>
                            <td class="cell-num text-body-secondary">{{ row.longlineCount }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <p class="text-body-secondary fst-italic text-center py-3 mb-0" data-data-table-target="empty" hidden>Nikdo nenalezen.</p>
    </section>
</div>
{% endblock %}
