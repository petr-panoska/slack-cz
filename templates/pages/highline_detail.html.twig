{% extends 'base.html.twig' %}

{% block title %}{{ highline.name }} – slack.cz{% endblock %}

{% block body %}
{% set cover = highline.coverPhoto %}
<article class="hl-detail{% if cover %} hl-detail-has-cover{% endif %}">
    <header class="hl-cover">
        {% if cover %}
            <img
                class="hl-cover-img"
                src="{{ vich_uploader_asset(cover, 'file') | imagine_filter('highline_full') }}"
                alt="{{ highline.name }}"
                loading="eager"
                decoding="async"
                onerror="this.closest('.hl-detail').classList.remove('hl-detail-has-cover'); this.remove();"
            >
        {% endif %}
        <div class="hl-cover-shade"></div>
        <div class="hl-cover-content">
            <a href="{{ path('app_highline_map') }}" class="hl-back">← Mapa</a>
            <h1>
                {{ highline.name }}
                {# Štítek je signál pro admina (verifikační workflow) — běžný návštěvník
                   ho nepotřebuje vidět, hlavně u 254 importovaných lajn. #}
                {% if not highline.isVerified and is_granted('ROLE_ADMIN') %}
                    <span class="hl-proposal-badge" title="Lajna ještě není ověřená adminem">navrženo</span>
                {% endif %}
            </h1>
            <div class="hl-detail-meta">
                <span class="hl-type-badge hl-type-{{ highline.type.value }}">{{ highline.type.label }}</span>
                {% if highline.firstAscentDate %}
                    <span class="hl-fa">První napnutí <time datetime="{{ highline.firstAscentDate|date('Y-m-d') }}">{{ highline.firstAscentDate|date('j. n. Y') }}</time></span>
                {% endif %}
            </div>
            {% if app.user %}
                {% set isAdmin = is_granted('ROLE_ADMIN') %}
                {% set isOwner = highline.isOwnedBy(app.user) %}
                {% set canEditDirect = isAdmin or (isOwner and not highline.isVerified) %}
                {% set canDelete = canEditDirect %}
                <div class="hl-detail-actions">
                    <a class="btn btn-secondary btn-sm" href="{{ path('app_highline_edit', { slug: highline.slug }) }}">
                        {{ canEditDirect ? 'Upravit' : 'Navrhnout úpravu' }}
                    </a>
                    {% if historyCount > 0 %}
                        <a class="btn btn-secondary btn-sm" href="{{ path('app_highline_history', { slug: highline.slug }) }}">Historie ({{ historyCount }})</a>
                    {% endif %}
                    {% if isAdmin and not highline.isVerified %}
                        <form method="post" action="{{ path('app_highline_verify', { slug: highline.slug }) }}" class="hl-action-form" data-turbo="false">
                            <input type="hidden" name="_token" value="{{ csrf_token('verify-highline-' ~ highline.id) }}">
                            <button type="submit" class="btn btn-primary btn-sm">Verifikovat</button>
                        </form>
                    {% endif %}
                    {% if canDelete %}
                        <form method="post" action="{{ path('app_highline_delete', { slug: highline.slug }) }}" class="hl-action-form" onsubmit="return confirm('Opravdu smazat lajnu „{{ highline.name|e('js') }}"?');" data-turbo="false">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-highline-' ~ highline.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">Smazat</button>
                        </form>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </header>

    <div class="hl-detail-body">
        <div class="hl-detail-grid">
            <aside class="hl-stats panel">
                <div class="hl-stats-row">
                    <div class="hl-stat">
                        <span class="hl-stat-icon" aria-hidden="true">↔</span>
                        <span class="hl-stat-value">{{ highline.length }}<span class="hl-stat-unit"> m</span></span>
                        <span class="hl-stat-label">Délka</span>
                    </div>
                    <div class="hl-stat">
                        <span class="hl-stat-icon" aria-hidden="true">↕</span>
                        <span class="hl-stat-value">{{ highline.height }}<span class="hl-stat-unit"> m</span></span>
                        <span class="hl-stat-label">Výška</span>
                    </div>
                </div>
                {% if highline.rating %}
                    <div class="hl-rating-large" aria-label="hodnocení {{ highline.rating }} z 5">
                        {% for s in 1..5 %}<span class="hl-star{% if s <= highline.rating %} on{% endif %}">★</span>{% endfor %}
                    </div>
                {% endif %}
            </aside>

            <section class="hl-info panel">
                {% if highline.description %}
                    <div class="hl-info-block hl-richtext">
                        <h2>Popis</h2>
                        {{ highline.description|nl2br }}
                    </div>
                {% endif %}

                <table class="hl-table">
                    {% if highline.pointOneInfo %}<tr><th>Kotvení bodu&nbsp;1</th><td class="hl-richtext">{{ highline.pointOneInfo|nl2br }}</td></tr>{% endif %}
                    {% if highline.pointTwoInfo %}<tr><th>Kotvení bodu&nbsp;2</th><td class="hl-richtext">{{ highline.pointTwoInfo|nl2br }}</td></tr>{% endif %}
                    {% if highline.tensioningMinutes %}<tr><th>Napínání</th><td>{{ highline.tensioningMinutes }} min</td></tr>{% endif %}
                    {% if highline.approachMinutes %}<tr><th>Přístup</th><td>{{ highline.approachMinutes }} min</td></tr>{% endif %}
                    {% if highline.firstAscentBy %}<tr><th>Autor 1. napnutí</th><td>{{ highline.firstAscentBy }}</td></tr>{% endif %}
                    {% if highline.firstAscentDate %}<tr><th>Datum 1. napnutí</th><td>{{ highline.firstAscentDate|date('j. n. Y') }}</td></tr>{% endif %}
                    {% if highline.nameHistory %}<tr><th>Historie názvu</th><td class="hl-richtext">{{ highline.nameHistory|nl2br }}</td></tr>{% endif %}
                    {% if highline.point1Latitude and highline.point1Longitude %}
                        <tr>
                            <th>GPS bod&nbsp;1</th>
                            <td>
                                <a href="https://mapy.cz/turisticka?source=coor&id={{ highline.point1Longitude }}%2C{{ highline.point1Latitude }}" target="_blank" rel="noopener">
                                    {{ highline.point1Latitude }}, {{ highline.point1Longitude }}
                                </a>
                            </td>
                        </tr>
                    {% endif %}
                    {% if highline.point2Latitude and highline.point2Longitude %}
                        <tr>
                            <th>GPS bod&nbsp;2</th>
                            <td>
                                <a href="https://mapy.cz/turisticka?source=coor&id={{ highline.point2Longitude }}%2C{{ highline.point2Latitude }}" target="_blank" rel="noopener">
                                    {{ highline.point2Latitude }}, {{ highline.point2Longitude }}
                                </a>
                            </td>
                        </tr>
                    {% endif %}
                    {% if highline.hasParking %}
                        <tr>
                            <th>Parkování</th>
                            <td>
                                <a href="https://mapy.cz/turisticka?source=coor&id={{ highline.parkingLongitude }}%2C{{ highline.parkingLatitude }}" target="_blank" rel="noopener">
                                    {{ highline.parkingLatitude }}, {{ highline.parkingLongitude }}
                                </a>
                            </td>
                        </tr>
                    {% endif %}
                </table>
            </section>

            {{ include('_partials/_highline_gallery.html.twig', {
                highline: highline,
                photos: photos,
                likeCounts: likeCounts,
                commentCounts: commentCounts,
                likedIds: likedIds,
            }) }}

            <section class="panel hl-map-panel">
                <header class="panel-header">
                    <div class="panel-title">
                        <span class="panel-dot panel-dot-map"></span>
                        <h2>Mapa</h2>
                    </div>
                </header>
                <div
                    class="hl-map-wrapper"
                    data-controller="highline-detail-map"
                    data-highline-detail-map-lat-value="{{ highline.latitude }}"
                    data-highline-detail-map-lng-value="{{ highline.longitude }}"
                    data-highline-detail-map-name-value="{{ highline.name }}"
                    {% if highline.hasPolyline %}
                    data-highline-detail-map-p1-lat-value="{{ highline.point1Latitude }}"
                    data-highline-detail-map-p1-lng-value="{{ highline.point1Longitude }}"
                    data-highline-detail-map-p2-lat-value="{{ highline.point2Latitude }}"
                    data-highline-detail-map-p2-lng-value="{{ highline.point2Longitude }}"
                    {% endif %}
                    {% if highline.hasParking %}
                    data-highline-detail-map-parking-lat-value="{{ highline.parkingLatitude }}"
                    data-highline-detail-map-parking-lng-value="{{ highline.parkingLongitude }}"
                    {% endif %}
                    data-highline-detail-map-icon-url-value="{{ asset('images/leaflet/marker-icon.png') }}"
                    data-highline-detail-map-icon-retina-url-value="{{ asset('images/leaflet/marker-icon-2x.png') }}"
                    data-highline-detail-map-shadow-url-value="{{ asset('images/leaflet/marker-shadow.png') }}"
                >
                    <div class="hl-map-canvas" data-highline-detail-map-target="canvas"></div>
                </div>
            </section>

            <section class="panel hl-crossings-panel">
                <header class="panel-header">
                    <div class="panel-title">
                        <span class="panel-dot panel-dot-crossings"></span>
                        <h2>Přechody <span class="hl-crossings-count">{{ crossings|length }}</span></h2>
                    </div>
                    {% if app.user %}
                        <a class="btn btn-primary btn-sm" href="{{ path('app_crossing_new', { slug: highline.slug }) }}">+ Přidat přechod</a>
                    {% else %}
                        <a class="btn btn-secondary btn-sm" href="{{ path('app_login') }}">Přihlásit pro přidání</a>
                    {% endif %}
                </header>
                {% if crossings|length > 0 %}
                    {{ include('_partials/_recent_crossings.html.twig', { crossings: crossings, layout: 'panel', show_line: false }) }}
                {% else %}
                    <p class="hl-empty">Zatím žádný zaznamenaný přechod.</p>
                {% endif %}
            </section>
        </div>
    </div>
</article>
{% endblock %}
