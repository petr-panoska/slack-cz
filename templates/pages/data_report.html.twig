{% extends 'base.html.twig' %}

{% block title %}Data report — slack.cz{% endblock %}

{% block body %}
<div class="page-grid">
    <header class="dr-header">
        <h1>Data report</h1>
        <p class="dr-sub">Kontrola a retuš dat naimportovaných z původní slack.cz. Prokliky vedou na legacy detail na produkci.</p>
    </header>

    {# ---- Sekce: lajny — kontrola dat ---- #}
    <section class="panel">
        <header class="panel-header">
            <div class="panel-title">
                <span class="panel-dot panel-dot-crossings"></span>
                <h2>Lajny <span class="dr-count">{{ lines|length }}</span></h2>
            </div>
        </header>

        <p class="dr-intro">
            <strong>Druhý bod</strong> = bez něj jde na mapě vykreslit jen bod, ne linka.
            <br>
            <strong>Cover fotka</strong> = titulní fotka lajny. Proklik: <code>{{ production_url }}/highlines/detail/{id}</code>.
        </p>

        {% if lines is empty %}
            <p class="dr-intro">Žádné lajny.</p>
        {% else %}
        <div class="dr-table-wrap">
            <table class="dr-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Název</th>
                        <th class="dr-num">Přechodů</th>
                        <th class="dr-bool">Druhý bod</th>
                        <th class="dr-bool">Cover fotka</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in lines %}
                    {% set line = row.line %}
                    {% set prod_url = line.legacyId ? production_url ~ '/highlines/detail/' ~ line.legacyId : null %}
                    {% set missing_second = line.point2Latitude is null or line.point2Longitude is null %}
                    <tr>
                        <td class="dr-id">{{ line.legacyId ?? line.id }}</td>
                        <td>
                            {% if prod_url %}
                                <a href="{{ prod_url }}" target="_blank" rel="noopener" class="dr-line">{{ line.name }}</a>
                            {% else %}
                                <span class="dr-line">{{ line.name }}</span>
                            {% endif %}
                        </td>
                        <td class="dr-num">{{ row.crossingCount }}</td>
                        <td class="dr-bool{{ missing_second ? ' dr-warn' }}">{{ missing_second ? '✗' : '✓' }}</td>
                        <td class="dr-bool{{ not row.hasCover ? ' dr-warn' }}">{{ row.hasCover ? '✓' : '✗' }}</td>
                        <td class="dr-go">
                            {% if prod_url %}
                                <a href="{{ prod_url }}" target="_blank" rel="noopener" title="Otevřít na produkci">↗</a>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </section>
</div>
{% endblock %}
