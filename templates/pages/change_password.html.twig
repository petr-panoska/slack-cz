{% extends 'base.html.twig' %}

{% block title %}Změnit heslo{% endblock %}

{% block body %}
    <div class="form-page form-page--sm">
        <div class="card">
            <div class="card-body p-4">
                <h1 class="h4 mb-4">Změnit heslo</h1>

                {{ form_start(form) }}
                    {{ form_row(form.currentPassword) }}

                    <hr class="my-4">

                    {{ form_row(form.newPassword) }}

                    {{ form_errors(form) }}

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">Uložit heslo</button>
                        <a class="btn btn-outline-secondary flex-fill" href="{{ path('app_user_diary', {'id': app.user.id}) }}">Zrušit</a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}

