{% extends 'base.html.twig' %}

{% block title %}Highline mapa{% endblock %}

{# Celostránková mapa — patička by jen ukusovala z výšky mapy. #}
{% block footer %}{% endblock %}

{% block body %}
<div
    class="line-map-wrapper"
    data-controller="map"
    data-map-data-url-value="{{ path('app_line_map_data') }}"
    data-map-users-url-value="{{ path('app_line_map_feed') }}"
    data-map-timeline-url-value="{{ path('app_line_map_timeline') }}"
    data-map-icon-url-value="{{ asset('images/leaflet/marker-icon.png') }}"
    data-map-icon-retina-url-value="{{ asset('images/leaflet/marker-icon-2x.png') }}"
    data-map-shadow-url-value="{{ asset('images/leaflet/marker-shadow.png') }}"
>
    {# Sloupec vedle mapy (desktop) / pruh nad mapou (mobil) — s mapou se
       nepřekrývá, aby seznam nepočítal lajny schované pod boxem. Jeden panel
       s taby Lajny/Přechody: sbalený = jen lišta aktivního tabu, rozbalený =
       oba taby + obsah aktivního. Výšku panelu táhne uživatel úchytem.
       Obsah tabů renderují line-feed / crossing-feed controllery na témže
       elementu; panel jim sbalování a výšku řídí přes map-panel controller. #}
    <div class="map-side">
        <aside
            class="map-panel"
            aria-label="Lajny a přechody na mapě"
            data-controller="map-panel line-feed crossing-feed"
            data-crossing-feed-url-value="{{ path('app_line_map_feed') }}"
            data-action="line-feed:collapse->map-panel#collapse line-feed:rendered->map-panel#refreshOverflow crossing-feed:rendered->map-panel#refreshOverflow"
        >
            <header class="map-panel__tabs" role="tablist">
                <button
                    type="button"
                    class="map-panel__tab btn btn-outline-primary btn-sm active"
                    id="map-panel-tab-lines"
                    role="tab"
                    aria-selected="true"
                    aria-controls="map-panel-pane-lines"
                    data-map-panel-target="linesTab"
                    data-map-panel-tab-param="lines"
                    data-action="map-panel#selectTab"
                >
                    Lajny<span class="map-panel__count" data-line-feed-target="count"></span>
                </button>
                <button
                    type="button"
                    class="map-panel__tab map-panel__tab--crossings btn btn-outline-primary btn-sm"
                    id="map-panel-tab-crossings"
                    role="tab"
                    aria-selected="false"
                    aria-controls="map-panel-pane-crossings"
                    data-map-panel-target="crossingsTab"
                    data-map-panel-tab-param="crossings"
                    data-action="map-panel#selectTab"
                >
                    Přechody
                    {# V buttonu je BUĎ počet přechodů, NEBO přeškrtnuté oko (markery
                       schované). Stav vlastní crossing-feed (default schované). #}
                    <span class="map-panel__count" data-crossing-feed-target="tabCount" hidden></span>
                    <span
                        class="map-panel__tab-eye"
                        data-crossing-feed-target="tabEye"
                        aria-hidden="true"
                    >
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3l18 18"/>
                            <path d="M10.6 6.2A10.1 10.1 0 0 1 12 6c6 0 9.5 7 9.5 7a14.7 14.7 0 0 1-3.3 4.1"/>
                            <path d="M6.2 7.8C3.9 9.6 2.5 12 2.5 12s3.5 7 9.5 7c1.6 0 3-.4 4.2-1"/>
                            <path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"/>
                        </svg>
                    </span>
                </button>
                <button
                    type="button"
                    class="map-panel__toggle"
                    data-map-panel-target="toggle"
                    data-action="map-panel#toggle"
                    aria-expanded="true"
                    aria-label="Sbalit panel"
                    title="Sbalit panel"
                >
                    <span class="map-panel__arrow" aria-hidden="true">▾</span>
                </button>
            </header>

            <div class="map-panel__body" data-map-panel-target="body">
                <section
                    class="map-panel__pane"
                    id="map-panel-pane-lines"
                    role="tabpanel"
                    aria-labelledby="map-panel-tab-lines"
                    data-map-panel-target="linesPane"
                >
                    <ul class="line-feed" data-line-feed-target="list"></ul>
                    <p class="map-panel__empty" data-line-feed-target="empty" hidden>Na mapě není žádná lajna :-(</p>
                </section>

                <section
                    class="map-panel__pane crossing-feed"
                    id="map-panel-pane-crossings"
                    role="tabpanel"
                    aria-labelledby="map-panel-tab-crossings"
                    data-map-panel-target="crossingsPane"
                    hidden
                >
                    {# Lišta filtru: caption rozbaluje filtr, oko schovává markery na mapě. #}
                    <div class="crossing-feed__bar">
                        <button
                            type="button"
                            class="crossing-feed__caption"
                            data-crossing-feed-target="caption"
                            data-action="crossing-feed#toggleFilter"
                            aria-expanded="false"
                            aria-controls="crossing-feed-filter"
                            title="Změnit filtr přechodů"
                        >Posledních 10 přechodů</button>
                        {# Default = markery schované (crossing_feed_controller) — button
                           startuje ve stavu --off, connect ho případně přepne. #}
                        <button
                            type="button"
                            class="crossing-feed__eye crossing-feed__eye--off"
                            data-crossing-feed-target="eye"
                            data-action="crossing-feed#toggleUsers"
                            aria-label="Zobrazit přechody na mapě"
                            title="Zobrazit přechody na mapě"
                        >
                            <svg class="crossing-feed__eye-icon-on" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M2.5 12s3.5-7 9.5-7 9.5 7 9.5 7-3.5 7-9.5 7S2.5 12 2.5 12z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            <svg class="crossing-feed__eye-icon-off" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M3 3l18 18"/>
                                <path d="M10.6 6.2A10.1 10.1 0 0 1 12 6c6 0 9.5 7 9.5 7a14.7 14.7 0 0 1-3.3 4.1"/>
                                <path d="M6.2 7.8C3.9 9.6 2.5 12 2.5 12s3.5 7 9.5 7c1.6 0 3-.4 4.2-1"/>
                                <path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"/>
                            </svg>
                        </button>
                    </div>
                    <div
                        class="crossing-feed__filter"
                        id="crossing-feed-filter"
                        data-crossing-feed-target="filter"
                        hidden
                    >
                        <label class="crossing-feed__filter-row">
                            <input
                                type="radio"
                                name="feed-filter-mode"
                                value="count"
                                checked
                                data-crossing-feed-target="modeCount"
                                data-action="change->crossing-feed#changeMode"
                            >
                            <span>Posledních</span>
                            <input
                                type="number"
                                min="1"
                                max="200"
                                value="10"
                                class="crossing-feed__filter-num"
                                aria-label="Počet posledních přechodů"
                                data-crossing-feed-target="count"
                                data-action="input->crossing-feed#changeCount"
                            >
                            <span>přechodů</span>
                        </label>
                        <label class="crossing-feed__filter-row">
                            <input
                                type="radio"
                                name="feed-filter-mode"
                                value="range"
                                data-crossing-feed-target="modeRange"
                                data-action="change->crossing-feed#changeMode"
                            >
                            <span>Rozsah dat</span>
                        </label>
                        <div class="crossing-feed__filter-range">
                            <input
                                type="date"
                                aria-label="Datum od"
                                data-crossing-feed-target="from"
                                data-action="change->crossing-feed#changeRange"
                            >
                            <span aria-hidden="true">–</span>
                            <input
                                type="date"
                                aria-label="Datum do"
                                data-crossing-feed-target="to"
                                data-action="change->crossing-feed#changeRange"
                            >
                        </div>
                    </div>
                    <ul class="crossing-feed__list" data-crossing-feed-target="list"></ul>
                    <p class="map-panel__empty" data-crossing-feed-target="empty" hidden>Zatím žádný přechod.</p>
                </section>
            </div>

            {# Úchyt obkročmo na spodní hraně — tažením (nebo šipkami ↑/↓) mění výšku panelu. #}
            <button
                type="button"
                class="map-panel__resize"
                data-action="pointerdown->map-panel#resizeStart keydown.up->map-panel#resizeKey keydown.down->map-panel#resizeKey"
                aria-label="Změnit výšku panelu"
                title="Tažením změníš výšku panelu"
            >
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <polyline points="8 9 12 5 16 9"/>
                    <polyline points="8 15 12 19 16 15"/>
                </svg>
            </button>
        </aside>
    </div>

    <div class="line-map" data-map-target="canvas"></div>

    {# TODO(mapa-mobile): „Přehrát historii" dočasně skryto — time-travel se vrátí
       až s mobilním redesignem ovládání (docs/todo.md § Mapa). map_controller má
       target guardovaný (hasTtToggleTarget), odkomentování ho zase oživí.
    <button
        type="button"
        class="map-tt-toggle"
        data-map-target="ttToggle"
        data-action="click->map#toggleTimeTravel"
    >Přehrát historii</button>
    #}

    <div class="map-tt-panel" data-map-target="ttPanel">
        <div class="map-tt-row">
            <button
                type="button"
                class="map-tt-play"
                data-map-target="ttPlay"
                data-action="click->map#togglePlay"
                aria-label="Přehrát"
            >▶</button>
            <span class="map-tt-date" data-map-target="ttDate">—</span>
            <input
                type="range"
                min="0"
                max="1000"
                value="0"
                step="1"
                class="map-tt-slider"
                data-map-target="ttSlider"
                data-action="change->map#seek"
                aria-label="Posun v čase"
            >
            <select
                class="map-tt-speed"
                data-map-target="ttSpeed"
                data-action="change->map#setSpeed"
                aria-label="Rychlost"
            >
                <option value="0.5">½×</option>
                <option value="1" selected>1×</option>
                <option value="2">2×</option>
                <option value="4">4×</option>
            </select>
        </div>
        <div class="map-tt-counter" data-map-target="ttCounter">Highlines: 0 · Přechody: 0</div>
    </div>
</div>
{% endblock %}
