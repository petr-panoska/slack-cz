{% extends 'base.html.twig' %}

{% block title %}{{ page.title ?: page.filename }} — {{ section_label }} — slack.cz{% endblock %}

{% block body %}
<article class="article md-section">
    <header class="md-section-head">
        <div class="md-section-meta">
            <a href="{{ page.githubUrl }}" target="_blank" rel="noopener" class="md-meta-link">
                Zobrazit na GitHubu
            </a>
            <span class="md-meta-sep">·</span>
            <a href="{{ page.githubEditUrl }}" target="_blank" rel="noopener" class="md-meta-link">
                Upravit
            </a>
        </div>
    </header>

    <div class="md-layout">
        {% include 'pages/_section/_sidebar.html.twig' %}

        <div class="md-main">
            {# Pokud frontmatter má title, render ho z metadata + ev. pull-quote nad body.
               Bez frontmatteru (typicky docs) tady nic není a body si svůj H1 nese sám. #}
            {% if page.title %}
                <h1 class="md-title">{{ page.title }}</h1>
                {% if page.quote %}
                    <blockquote class="md-quote">{{ page.quote }}</blockquote>
                {% endif %}
            {% endif %}
            <div class="md-prose">
                {{ body_html|raw }}
            </div>
        </div>
    </div>
</article>
{% endblock %}
