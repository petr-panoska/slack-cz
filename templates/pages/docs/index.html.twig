{% extends 'base.html.twig' %}

{% block title %}Docs — slack.cz{% endblock %}

{% block body %}
<article class="article docs-show">
    {% if readme is null %}
        <p class="docs-empty">
            Dokumentace je momentálně nedostupná (GitHub neodpovídá a nemáme uložený poslední dobrý stav). Zkus to za chvíli.
        </p>
    {% else %}
        <header class="docs-show-head">
            <div class="docs-show-meta">
                <a href="{{ readme.githubUrl }}" target="_blank" rel="noopener" class="docs-meta-link">
                    Zobrazit na GitHubu
                </a>
                <span class="docs-meta-sep">·</span>
                <a href="{{ readme.githubEditUrl }}" target="_blank" rel="noopener" class="docs-meta-link">
                    Upravit
                </a>
            </div>
        </header>

        <div class="docs-layout">
            <aside class="docs-sidebar">
                <ul class="docs-sidebar-list">
                    {% for entry in entries %}
                        {% set isReadme = entry.slug|lower == 'readme' %}
                        <li>
                            <a
                                href="{{ isReadme ? path('app_docs_index') : path('app_docs_show', {slug: entry.slug}) }}"
                                class="docs-sidebar-link {% if isReadme %}is-active{% endif %}"
                            >{{ entry.filename }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </aside>

            <div class="docs-prose">
                {{ body_html|raw }}
            </div>
        </div>
    {% endif %}
</article>
{% endblock %}
