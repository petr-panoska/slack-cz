beta.slack.cz {
	root * /var/www/slack-cz/public
	encode gzip zstd

	# Foto galerie — originály v /uploads/line/{id}/<uniqid>.ext, thumby
	# v /media/cache/{filter}/... s hash v cestě. Obsah pod konkrétní URL je
	# immutable, takže max-age 30 dní + immutable hint zachrání round-tripy.
	@photos path /uploads/* /media/cache/*
	header @photos Cache-Control "public, max-age=2592000, immutable"

	php_fastcgi unix//run/php/php8.3-fpm.sock
	file_server
}

# Self-hosted Matomo (viz docs/deploy.md § Analytics). Sdílí php-fpm socket
# s hlavní appkou — jiný `root` na request stačí, žádný samostatný pool.
#
# ⚠ NEDEPLOYOVAT (make deployCaddy) dřív, než existuje DNS záznam pro
# analytics.slack.cz — viz Gotchas "DNS records dřív než Caddy site block"
# v docs/deploy.md, jinak si veřejné resolvery uloží NXDOMAIN do negative cache.
analytics.slack.cz {
	root * /var/www/analytics
	encode gzip zstd

	# Matomo počítá s ochranou přes .htaccess (Apache) pro tyhle adresáře —
	# Caddy .htaccess neumí, takže to nahrazujeme explicitním denym. Žádný
	# z nich není určený k přímému browser přístupu, jen k internímu use
	# frontcontrollerem. Viz Matomo system-check "PHP SAPI" warning.
	@matomoInternal path /config/* /tmp/* /core/* /lang/*
	respond @matomoInternal 403

	php_fastcgi unix//run/php/php8.3-fpm.sock
	file_server
}

# Docker smoke test — hello-world kontejner (traefik/whoami), viz docs/deploy.md
test.slack.cz {
	reverse_proxy 127.0.0.1:8081
}
